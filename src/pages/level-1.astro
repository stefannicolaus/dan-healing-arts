---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import TestimonialDivider from '../components/TestimonialDivider.astro';
import TrainingCard from '../components/TrainingCard.astro';
import ApplyButton from '../components/ApplyButton.astro';
import Parallax from '../components/Parallax.astro';
import TextImageSection from '../components/TextImageSection.astro';
import FadeIn from '../components/FadeIn.astro';

const allTestimonials = await getCollection('testimonials');
const nicoUSA = allTestimonials.find(t => t.id === 'nico-usa')?.data;
const erikaLithuania = allTestimonials.find(t => t.id === 'erika-lithuania')?.data;
const paigeUSA = allTestimonials.find(t => t.id === 'paige-usa')?.data;
const jiliUSA = allTestimonials.find(t => t.id === 'jili-usa')?.data;
const rebeccaCanada = allTestimonials.find(t => t.id === 'rebecca-canada')?.data;

const learnTopics = [
  'The foundational principles of deep bodywork through muscle and fascia',
  'An overview of the key fascial lines and how to access them through touch',
  'The psycho-emotional language of the body - how different areas hold stories and patterns',
  'Cultivating connection with yourself to enhance your ability to hold presence and connection with clients throughout a session',
  'Applying pressure with sensitivity: long, deep, and slow strokes that invite safety and openness for physical and emotional release',
  'How to read the body, listen with your hands and follow its natural architecture, rhythms, and signals',
  'Bridging modern anatomy with traditional spiritual wisdom, making subtle energy accessible and tangible',
  'Using your bodyweight efficiently to offer deep touch in a gentle, sustainable way',
  'Crafting sessions and sequences for different purpose, tailored for release and healing',
  'The art of slowing down - not only in treatments, but in life itself',
  'Hands-on learning about fascia, trigger points, and energy dynamics',
  'Structured sequences that support intuition, clarity, and creative flow',
];

const bodyRegions = [
  { area: 'Upper back, lower back, neck', theme: 'Looking back on the past to move forward' },
  { area: 'Legs, feet', theme: 'Grounding into Mother Earth' },
  { area: 'Abdomen, hips, pelvis', theme: 'Unleash your potential' },
  { area: 'Thorax, chest, shoulders, arms', theme: 'Expansion of the heart' },
  { area: 'Head, face, throat, neck', theme: 'Sky as space in your head' },
];

const schedule = [
  { time: '08:00', activity: 'Yoga, breathwork, chanting, sharing' },
  { time: '09:15', activity: 'Breakfast' },
  { time: '10:00', activity: 'Massage demo and practice' },
  { time: '13:30', activity: 'Lunch and break' },
  { time: '15:30', activity: 'Massage demo and practice' },
  { time: '18:30', activity: 'Sharing and closing for the day' },
  { time: '19:00', activity: 'Dinner' },
  { time: '20:00', activity: 'Different rituals and group activities (optional)' },
];
---

<Layout
  lang="en"
  title="Level 1: The Essence of Deep Touch — Dan Healing Arts"
  description="The foundational training in a professional two-level pathway in fascia-based somatic bodywork. Learn deep touch, myofascial release, and the psycho-emotional language of the body."
  canonicalPath="/level-1"
>
  <Nav lang="en" />

  <main>

    <!-- ===== 1. HERO / INTRO ===== -->
    <FadeIn>
    <section class="pt-32 pb-24 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto">
        <TextImageSection image="/images/level1/hero.jpg" imageAlt="Level 1 bodywork training participants practicing deep touch">
          <h1 class="font-serif text-4xl md:text-5xl text-text-main mb-6 leading-tight">
            The Essence of Deep Touch
          </h1>
          <p class="font-sans text-stone text-lg italic mb-10 leading-relaxed">
            The foundational training in a professional two-level pathway in fascia-based somatic bodywork.
          </p>
          <div class="font-sans text-stone leading-relaxed space-y-4">
            <p>
              The Essence of Deep Touch is the foundational training in a professional two-level pathway in fascia-based somatic bodywork. It can later be followed by the advanced Level 2 training.
            </p>
            <p>
              The Training invites you into a grounded, somatic approach to deep, slow bodywork - woven with presence, curiosity and care. It's also a journey of self-exploration, opening space to feel and be felt more deeply.
            </p>
            <p>
              You'll learn how to work with muscles and fascia through the principles of deep touch, while gaining insight into the emotional qualities stored within different body regions. Physical, energetic, and psycho-emotional layers are all part of the unfolding.
            </p>
            <p>
              Each day offers hands-on practice and the gift of receiving. This shared rhythm brings balance to your body, mind and nervous system - and lets you explore both the art of giving and the medicine of being touched.
            </p>
            <p>
              You'll reconnect to the primal need for presence and care, for feeling yourself and others. Through meaningful work, rooted in awareness and connection, you'll leave with real, embodied skills ready to share.
            </p>
          </div>
        </TextImageSection>
      </div>
    </section>
    </FadeIn>

    <!-- ===== TESTIMONIAL: NICO, USA ===== -->
    {nicoUSA && (
      <TestimonialDivider
        quote={nicoUSA.quote}
        name={nicoUSA.name}
        location={nicoUSA.location}
        photo={nicoUSA.photo}
      />
    )}

    <!-- ===== 2. A PRACTICAL APPROACH ===== -->
    <FadeIn>
    <section class="py-24 px-6 md:px-12 bg-surface-lo">
      <div class="max-w-page mx-auto">
        <TextImageSection image="/images/level1/outside-5.jpg" imageAlt="Participants learning bodywork in an outdoor natural setting" reversed>
          <h2 class="font-serif text-3xl md:text-4xl text-text-main mb-8">
            A Practical Approach to Learning in a Natural Environment
          </h2>
          <div class="font-sans text-stone leading-relaxed space-y-4">
            <p>
              Set in a retreat space surrounded by nature, the training offers a spacious rhythm to slow down and reconnect - with yourself and others. Each teaching is infused with presence, embodiment, and ease.
            </p>
            <p>
              Rather than memorizing content, you'll absorb it through touch and practice. You'll begin to feel the structures from the inside out, letting anatomical and energetic maps come alive in your own body.
            </p>
            <p>
              This experiential learning creates a deep foundation. You'll feel how the body responds to trust, touch, and connection - and discover within yourself an inner landscape of awareness, resilience, and healing.
            </p>
          </div>
        </TextImageSection>
      </div>
    </section>
    </FadeIn>

    <!-- ===== TESTIMONIAL: ERIKA, LITHUANIA ===== -->
    {erikaLithuania && (
      <TestimonialDivider
        quote={erikaLithuania.quote}
        name={erikaLithuania.name}
        location={erikaLithuania.location}
        photo={erikaLithuania.photo}
      />
    )}

    <!-- ===== 3. WHAT YOU'LL LEARN ===== -->
    <FadeIn>
    <section class="py-24 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto">
        <TextImageSection image="/images/level1/inside-72.jpg" imageAlt="Students learning deep tissue and fascia bodywork techniques indoors">
          <h2 class="font-serif text-3xl md:text-4xl text-text-main mb-10">
            Learn and Embody the Following Topics with Playful Ease
          </h2>
          <ol class="font-sans text-stone leading-relaxed space-y-4">
            {learnTopics.map((topic, i) => (
              <li class="flex items-start gap-4">
                <span class="font-serif text-forest text-lg font-bold shrink-0 w-6 text-right">
                  {i + 1}.
                </span>
                <span>{topic}</span>
              </li>
            ))}
          </ol>
        </TextImageSection>
      </div>
    </section>
    </FadeIn>

    <!-- ===== PARALLAX — after What You'll Learn ===== -->
    <Parallax src="/images/level1/inside-12.jpg" height="45vh" />

    <!-- ===== TESTIMONIAL: PAIGE, USA ===== -->
    {paigeUSA && (
      <TestimonialDivider
        quote={paigeUSA.quote}
        name={paigeUSA.name}
        location={paigeUSA.location}
        photo={paigeUSA.photo}
      />
    )}

    <!-- ===== 4. EXPLORING THE BODY ===== -->
    <FadeIn>
    <section class="py-24 px-6 md:px-12 bg-surface-lo">
      <div class="max-w-page mx-auto max-w-3xl">
        <div class="mb-12 rounded-card overflow-hidden">
          <img
            src="/images/level1/inside-22.jpg"
            alt="Practitioner exploring body regions during a bodywork training session"
            class="w-full h-auto object-cover"
            loading="lazy"
          />
        </div>
        <h2 class="font-serif text-3xl md:text-4xl text-text-main mb-6">
          Exploring the Body through its Emotional Language
        </h2>
        <p class="font-sans text-stone leading-relaxed mb-10">
          The training unfolds in two parts:
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-14">
          <div class="bg-canvas rounded-card p-8">
            <h3 class="font-serif text-xl text-text-main mb-3">Days 1–3: Fundamentals</h3>
            <p class="font-sans text-stone leading-relaxed">
              You'll learn the essentials of a full-body deep touch session - from structure to flow.
            </p>
          </div>
          <div class="bg-canvas rounded-card p-8">
            <h3 class="font-serif text-xl text-text-main mb-3">Days 4–6: In Depth</h3>
            <p class="font-sans text-stone leading-relaxed">
              We deepen into specific body areas and their emotional qualities, working through the full body in cyclical, integrative ways.
            </p>
          </div>
        </div>

        <ul class="font-sans text-stone leading-relaxed space-y-4">
          {bodyRegions.map(({ area, theme }) => (
            <li class="flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-4 border-b border-stone/10 pb-4 last:border-0 last:pb-0">
              <span class="text-text-main font-medium shrink-0">{area}</span>
              <span class="text-stone/70 hidden sm:block">—</span>
              <span class="italic">{theme}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>
    </FadeIn>

    <!-- ===== TESTIMONIAL: JILI, USA ===== -->
    {jiliUSA && (
      <TestimonialDivider
        quote={jiliUSA.quote}
        name={jiliUSA.name}
        location={jiliUSA.location}
        photo={jiliUSA.photo}
      />
    )}

    <!-- ===== 5. YOGA, BREATHWORK, MEDITATION ===== -->
    <FadeIn>
    <section class="py-24 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto">
        <TextImageSection image="/images/level1/outside-27.jpg" imageAlt="Group yoga and breathwork practice outdoors during the training" reversed>
          <h2 class="font-serif text-3xl md:text-4xl text-text-main mb-8">
            Yoga, Breathwork, Meditation and Voice Activation
          </h2>
          <div class="font-sans text-stone leading-relaxed space-y-4">
            <p>
              Daily yoga and breathwork sessions support the themes of each day, grounding the body and opening your awareness. These embodied practices deepen the work and nourish your nervous system.
            </p>
            <p>
              Group chanting, voice work and sharing circles invite you into expression and connection, while guided meditations and stories from yoga philosophy add context and depth to your journey.
            </p>
            <p>
              Together, these practices create an integrated inner and outer retreat - an immersion into body, energy and presence.
            </p>
          </div>
        </TextImageSection>
      </div>
    </section>
    </FadeIn>

    <!-- ===== PARALLAX — before Sample Day Schedule ===== -->
    <Parallax src="/images/level1/outside-5.jpg" height="45vh" />

    <!-- ===== 6. SCHEDULE ===== -->
    <FadeIn>
    <section class="py-24 px-6 md:px-12 bg-surface-lo">
      <div class="max-w-page mx-auto">
        <h2 class="font-serif text-3xl md:text-4xl text-text-main mb-10">
          Sample Day Schedule
        </h2>
        <div class="max-w-2xl rounded-card overflow-hidden border border-stone/10 shadow-sm">
          <table class="w-full font-sans">
            <tbody>
              {schedule.map(({ time, activity }, i) => (
                <tr class={`${i % 2 === 0 ? 'bg-canvas' : 'bg-surface-lo'} last:border-0`}>
                  <td class="py-4 pl-6 pr-6 w-28 align-middle">
                    <div class="flex items-center gap-3">
                      <!-- Timeline dot -->
                      <span class="shrink-0 w-2 h-2 rounded-full bg-forest/40 block"></span>
                      <span class="font-serif text-forest font-bold text-base whitespace-nowrap">{time}</span>
                    </div>
                  </td>
                  <td class="py-4 pr-6 text-stone leading-relaxed border-l border-stone/10">
                    <span class="pl-4 block">{activity}</span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>
    </FadeIn>

    <!-- ===== TESTIMONIAL: REBECCA, CANADA ===== -->
    {rebeccaCanada && (
      <TestimonialDivider
        quote={rebeccaCanada.quote}
        name={rebeccaCanada.name}
        location={rebeccaCanada.location}
        photo={rebeccaCanada.photo}
      />
    )}

    <!-- ===== 7. UPCOMING TRAININGS ===== -->
    <FadeIn>
    <section class="py-24 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto">
        <h2 class="font-serif text-3xl md:text-4xl text-text-main mb-10">
          Upcoming Level 1 Trainings
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-10">
          <TrainingCard
            title="The Essence of Deep Touch"
            date="1–7 June 2026"
            location="Portugal"
            level="Level 1"
            href="/portugal"
          />
          <TrainingCard
            title="Level 1a — Rücken & Nacken"
            date="18–19 April 2026"
            location="Zürich"
            level="Level 1a"
            href="/zurich"
          />
          <TrainingCard
            title="Level 1b — Bauch, Becken, Beine"
            date="13–14 June 2026"
            location="Zürich"
            level="Level 1b"
            href="/zurich"
          />
          <TrainingCard
            title="The Essence of Deep Touch"
            date="24–30 January 2027"
            location="Mazunte, México"
            level="Level 1"
            href="/mazunte"
          />
        </div>
        <ApplyButton />
      </div>
    </section>
    </FadeIn>

  </main>

  <Footer lang="en" />

</Layout>
