---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import TestimonialDivider from '../components/TestimonialDivider.astro';
import TrainingCard from '../components/TrainingCard.astro';
import ApplyButton from '../components/ApplyButton.astro';
import Parallax from '../components/Parallax.astro';
import TextImageSection from '../components/TextImageSection.astro';
import FadeIn from '../components/FadeIn.astro';
import StatsDivider from '../components/StatsDivider.astro';
import { getRetreat, getTrainings, getTestimonials } from '../lib/content';

const allTrainings = await getTrainings();
const level1Trainings = allTrainings.filter((t: any) => ['Level 1', 'Level 1a', 'Level 1b'].includes(t.level));

const allTestimonials = await getTestimonials();
const nicoUSA = allTestimonials.find((t: any) => t.name === 'Nico' && t.location?.includes('USA'));
const erikaLithuania = allTestimonials.find((t: any) => t.name === 'Erika' && t.location?.includes('Lithuania'));
const paigeUSA = allTestimonials.find((t: any) => t.name === 'Paige' && t.location?.includes('USA'));
const jiliUSA = allTestimonials.find((t: any) => t.name === 'Jili' && t.location?.includes('USA'));
const rebeccaCanada = allTestimonials.find((t: any) => t.name === 'Rebecca' && t.location?.includes('Canada'));

const pageData = await getRetreat('level-1');
const learnTopics = pageData?.learn_topics ?? [];
const bodyRegions = pageData?.body_regions ?? [];
---

<Layout
  lang="en"
  title={pageData?.page_title ?? "Level 1: The Essence of Deep Touch — Dan Healing Arts"}
  description={pageData?.page_description ?? "The foundational training in a professional two-level pathway in fascia-based somatic bodywork. Learn deep touch, myofascial release, and the psycho-emotional language of the body."}
  canonicalPath="/level-1"
>
  <Nav lang="en" />

  <main>

    <!-- ===== 1. HERO / INTRO ===== -->
    <FadeIn>
    <section class="pt-32 pb-24 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto">
        <TextImageSection image={pageData?.hero_image ?? "/images/level1/hero.jpg"} imageAlt="Level 1 bodywork training participants practicing deep touch" imagePosition="center">
          <p class="font-sans text-xs font-bold uppercase tracking-[0.15rem] text-forest mb-4">{pageData?.hero_badge ?? "Level 1 Training"}</p>
          <h1 class="font-serif text-4xl md:text-5xl text-text-main mb-6 leading-tight">
            {pageData?.hero_heading ?? "The Essence of Deep Touch"}
          </h1>
          <p class="font-sans text-stone text-lg italic mb-10 leading-relaxed">
            {pageData?.hero_subheading ?? "The foundational training in a professional two-level pathway in fascia-based somatic bodywork."}
          </p>
          <div class="font-sans text-stone leading-relaxed space-y-4">
            {(pageData?.hero_paragraphs ?? []).map((p: string) => <p>{p}</p>)}
          </div>
        </TextImageSection>
      </div>
    </section>
    </FadeIn>

    <!-- ===== TESTIMONIAL: NICO, USA ===== -->
    {nicoUSA && (
      <TestimonialDivider
        quote={nicoUSA.quote}
        name={nicoUSA.name}
        location={nicoUSA.location}
        photo={nicoUSA.photo}
      />
    )}

    <!-- ===== 2. A PRACTICAL APPROACH ===== -->
    {pageData?.sections?.filter(s => s.id === 'practical_approach').map((section) => (
      <FadeIn>
      <section class="py-12 md:py-16 px-6 md:px-12 bg-canvas">
        <div class="max-w-page mx-auto">
          <TextImageSection image={section.image} imageAlt={section.imageAlt ?? ''} reversed={section.reversed ?? false} imagePosition={section.imagePosition ?? 'center'}>
            {section.heading && (
              <h2 class="font-serif text-3xl md:text-4xl text-text-main mb-8">{section.heading}</h2>
            )}
            <div class="font-sans text-stone leading-relaxed space-y-4">
              {section.paragraphs.map((p: string) => <p>{p}</p>)}
            </div>
          </TextImageSection>
        </div>
      </section>
      </FadeIn>
    ))}

    <!-- ===== TESTIMONIAL: ERIKA, LITHUANIA ===== -->
    {erikaLithuania && (
      <TestimonialDivider
        quote={erikaLithuania.quote}
        name={erikaLithuania.name}
        location={erikaLithuania.location}
        photo={erikaLithuania.photo}
      />
    )}

    <!-- ===== 3. WHAT YOU'LL LEARN — Part 1 ===== -->
    <FadeIn>
    <section class="py-12 md:pb-6 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto">
        <TextImageSection image="/images/level1/inside-72.jpg" imageAlt="Students learning deep tissue and fascia bodywork techniques indoors">
          <h2 class="font-serif text-3xl md:text-4xl text-text-main mb-10">
            Learn and Embody the Following Topics with Playful Ease
          </h2>
          <ul class="font-sans text-stone leading-relaxed space-y-4">
            {learnTopics.slice(0, 6).map((topic) => (
              <li class="flex items-start gap-3">
                <span class="text-forest font-bold shrink-0 mt-0.5">•</span>
                <span>{topic}</span>
              </li>
            ))}
          </ul>
        </TextImageSection>
      </div>
    </section>
    </FadeIn>

    <!-- ===== 3b. WHAT YOU'LL LEARN — Part 2 ===== -->
    <FadeIn>
    <section class="py-6 md:py-12 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto">
        <TextImageSection image="/images/level1/inside-12.jpg" imageAlt="Hands-on bodywork practice during the Level 1 training" reversed>
          <ul class="font-sans text-stone leading-relaxed space-y-4">
            {learnTopics.slice(6).map((topic) => (
              <li class="flex items-start gap-3">
                <span class="text-forest font-bold shrink-0 mt-0.5">•</span>
                <span>{topic}</span>
              </li>
            ))}
          </ul>
        </TextImageSection>
      </div>
    </section>
    </FadeIn>

    <!-- ===== PARALLAX — after What You'll Learn ===== -->
    <Parallax src="/images/level1/outside-5.jpg" height="45vh" />

    <!-- ===== TESTIMONIAL: PAIGE, USA ===== -->
    {paigeUSA && (
      <TestimonialDivider
        quote={paigeUSA.quote}
        name={paigeUSA.name}
        location={paigeUSA.location}
        photo={paigeUSA.photo}
      />
    )}

    <!-- ===== 4a. EXPLORING THE BODY — Part 1 ===== -->
    <FadeIn>
    <section class="py-12 md:pb-6 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto">
        <TextImageSection image="/images/level1/inside-hall.jpg" imageAlt="Practitioners working on body regions during a training session">
          <h2 class="font-serif text-3xl md:text-4xl text-text-main mb-6">
            Exploring the Body through its Emotional Language
          </h2>
          <p class="font-sans text-stone leading-relaxed mb-8">
            The training unfolds in two parts:
          </p>
          <div class="space-y-6">
            <div class="bg-surface-lo rounded-card p-6">
              <h3 class="font-serif text-xl text-text-main mb-2">Days 1–3: Fundamentals</h3>
              <p class="font-sans text-stone leading-relaxed">
                You'll learn the essentials of a full-body deep touch session - from structure to flow.
              </p>
            </div>
            <div class="bg-surface-lo rounded-card p-6">
              <h3 class="font-serif text-xl text-text-main mb-2">Days 4–6: In Depth</h3>
              <p class="font-sans text-stone leading-relaxed">
                We deepen into specific body areas and their emotional qualities, working through the full body in cyclical, integrative ways.
              </p>
            </div>
          </div>
        </TextImageSection>
      </div>
    </section>
    </FadeIn>

    <!-- ===== 4b. EXPLORING THE BODY — Part 2: Body Regions ===== -->
    <FadeIn>
    <section class="py-6 md:py-12 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto">
        <TextImageSection image="/images/level1/outside-5.jpg" imageAlt="Training participants outdoors in a natural retreat setting" reversed>
          <ul class="font-sans text-stone leading-relaxed space-y-5">
            {bodyRegions.map(({ area, theme }) => (
              <li class="border-b border-stone/10 pb-5 last:border-0 last:pb-0">
                <span class="text-text-main font-medium">{area}</span>
                <br/>
                <span class="italic">{theme}</span>
              </li>
            ))}
          </ul>
        </TextImageSection>
      </div>
    </section>
    </FadeIn>

    <!-- ===== TESTIMONIAL: JILI, USA ===== -->
    {jiliUSA && (
      <TestimonialDivider
        quote={jiliUSA.quote}
        name={jiliUSA.name}
        location={jiliUSA.location}
        photo={jiliUSA.photo}
      />
    )}

    <!-- ===== 5. YOGA, BREATHWORK, MEDITATION ===== -->
    {pageData?.sections?.filter(s => s.id === 'yoga_breathwork').map((section) => (
      <FadeIn>
      <section class="py-12 md:py-16 px-6 md:px-12 bg-canvas">
        <div class="max-w-page mx-auto">
          <TextImageSection image={section.image} imageAlt={section.imageAlt ?? ''} reversed={section.reversed ?? false} imagePosition={section.imagePosition ?? 'center'}>
            {section.heading && (
              <h2 class="font-serif text-3xl md:text-4xl text-text-main mb-8">{section.heading}</h2>
            )}
            <div class="font-sans text-stone leading-relaxed space-y-4">
              {section.paragraphs.map((p: string) => <p>{p}</p>)}
            </div>
          </TextImageSection>
        </div>
      </section>
      </FadeIn>
    ))}

    <!-- ===== PARALLAX ===== -->
    <Parallax src="/images/level1/inside-12.jpg" height="45vh" position="center 20%" />

    <!-- ===== TESTIMONIAL: REBECCA, CANADA ===== -->
    {rebeccaCanada && (
      <TestimonialDivider
        quote={rebeccaCanada.quote}
        name={rebeccaCanada.name}
        location={rebeccaCanada.location}
        photo={rebeccaCanada.photo}
      />
    )}

    <!-- ===== 6. UPCOMING TRAININGS ===== -->
    <FadeIn>
    <section class="py-12 md:py-16 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto">
        <h2 class="font-serif text-3xl md:text-4xl text-text-main mb-10">
          Upcoming Level 1 Trainings
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-10">
          {level1Trainings.map((t: any) => (
            <TrainingCard
              title={t.title}
              date={t.date}
              location={t.location}
              level={t.level}
              href={t.href}
              image={t.image}
              status={t.status}
              spots_left={t.spots_left}
            />
          ))}
        </div>
        <ApplyButton />
      </div>
    </section>
    </FadeIn>

  </main>

  <Footer lang="en" />

</Layout>
