---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import ZurichHero from '../components/ZurichHero.astro';
import ZurichMethode from '../components/ZurichMethode.astro';
import ZurichWasEntwickelst from '../components/ZurichWasEntwickelst.astro';
import ZurichErfahrungsraum from '../components/ZurichErfahrungsraum.astro';
import ZurichModule from '../components/ZurichModule.astro';
import ZurichTestimonials from '../components/ZurichTestimonials.astro';
import ZurichUeberDaniel from '../components/ZurichUeberDaniel.astro';
import ZurichKontakt from '../components/ZurichKontakt.astro';
import Parallax from '../components/Parallax.astro';
import StatsDivider from '../components/StatsDivider.astro';
import Footer from '../components/Footer.astro';
import FadeIn from '../components/FadeIn.astro';
import TestimonialDivider from '../components/TestimonialDivider.astro';
import { getStartseite, getTestimonials } from '../lib/queries';
import { imageUrl } from '../lib/sanity';

const s = await getStartseite();
const allTestimonials = await getTestimonials();
const nicoUSA = allTestimonials.find((t: any) => t.name === 'Nico' && t.location?.includes('USA'));
const ilincaGermany = allTestimonials.find((t: any) => t.name === 'Ilinca' && t.location?.includes('Germany'));

const heroBild = imageUrl(s?.hero_bild, '/images/general/dan-outside-38.jpg');
---

<Layout
  lang="de"
  title="Somatische Tiefenmassage & Faszien Release — Wochenendkurse Zürich | Dan Healing Arts"
  description="Lerne präzise Faszienarbeit mit somatischer Präsenz. 4 Wochenendkurse in Zürich mit Daniel Wendt. Einzeln buchbar, je 420 CHF."
  canonicalPath="/zurich"
>
  <Nav lang="en" />
  <main>
    <ZurichHero
      headline={s?.hero_headline ?? 'Lerne, mit deinen Händen zu hören.'}
      subtext={s?.hero_subtext ?? ''}
      cta_text={s?.hero_cta_text ?? 'Jetzt anmelden'}
      cta_link={s?.hero_cta_href ?? '/contact'}
      bild={heroBild}
      bildAlt="Daniel Wendt — Dan Healing Arts"
    />
    <StatsDivider />
    <FadeIn>
      <ZurichMethode
        label={s?.methode_label}
        heading={s?.methode_heading}
        paragraphs={s?.methode_paragraphs ?? []}
        highlight={s?.methode_highlight}
      />
    </FadeIn>
    <Parallax src={s?.parallax_1 ?? '/images/parallax-1.jpg'} height="50vh" />
    <FadeIn>
      <ZurichWasEntwickelst
        label={s?.entwickelst_label}
        heading={s?.entwickelst_heading}
        paragraphs={s?.entwickelst_paragraphs ?? []}
        highlight={s?.entwickelst_highlight}
        image={s?.entwickelst_bild}
        imageAlt={s?.entwickelst_label ?? ''}
      />
    </FadeIn>
    <FadeIn>
      <ZurichErfahrungsraum
        label={s?.erfahrungsraum_label}
        heading={s?.erfahrungsraum_heading}
        paragraphs={s?.erfahrungsraum_paragraphs ?? []}
        highlight={s?.erfahrungsraum_highlight}
        image={s?.erfahrungsraum_bild}
        imageAlt={s?.erfahrungsraum_label ?? ''}
      />
    </FadeIn>
    <FadeIn><ZurichModule /></FadeIn>
    {nicoUSA && (
      <TestimonialDivider
        quote={nicoUSA.quote}
        name={nicoUSA.name}
        location={nicoUSA.location}
        photo={nicoUSA.photo}
      />
    )}
    <ZurichTestimonials />
    {ilincaGermany && (
      <TestimonialDivider
        quote={ilincaGermany.quote}
        name={ilincaGermany.name}
        location={ilincaGermany.location}
        photo={ilincaGermany.photo}
      />
    )}
    <StatsDivider />
    <FadeIn>
      <ZurichUeberDaniel
        heading={s?.ueber_heading}
        paragraphs={s?.ueber_paragraphs ?? []}
        stats={s?.ueber_stats}
        image={s?.ueber_bild}
      />
    </FadeIn>
    <Parallax src={s?.parallax_2 ?? '/images/parallax-2.jpg'} height="50vh" />
    <FadeIn><ZurichKontakt /></FadeIn>
  </main>
  <Footer lang="de" />
</Layout>
