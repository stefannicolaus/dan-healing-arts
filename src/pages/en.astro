---
import { getCollection, getEntry } from 'astro:content';
const allTrainingsEntries = await getCollection('trainings');
const trainings = allTrainingsEntries.map(t => t.data);
const pageData = (await getEntry('pages', 'en'))?.data;
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import TestimonialDivider from '../components/TestimonialDivider.astro';
import TrainingCard from '../components/TrainingCard.astro';
import ApplyButton from '../components/ApplyButton.astro';
import Parallax from '../components/Parallax.astro';
import FadeIn from '../components/FadeIn.astro';
import StatsDivider from '../components/StatsDivider.astro';

const allTestimonials = await getCollection('testimonials');
const elyUK = allTestimonials.find(t => t.id === 'ely-uk')?.data;
const janeUSA = allTestimonials.find(t => t.id === 'jane-usa')?.data;
---

<Layout
  lang="en"
  title={pageData?.page_title ?? "Dan Healing Arts — Learn to Listen with Your Hands"}
  description={pageData?.page_description ?? "Immersive trainings in deep, slow somatic bodywork — woven with presence, curiosity and care. A professional pathway in fascia-based bodywork."}
  canonicalPath="/"
>
  <Nav lang="en" />

  <main>

    <!-- ===== 1. HERO ===== -->
    <section class="relative min-h-screen flex items-center pt-28 pb-16 md:pt-32 md:pb-24 bg-canvas">
      <div class="max-w-page mx-auto px-6 md:px-12 grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16 items-center">

        <!-- Text -->
        <div>
          <p class="font-sans text-stone text-xs uppercase tracking-[0.25em] mb-6">{pageData?.hero.badge ?? "Dan Healing Arts"}</p>
          <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl text-text-main leading-[1.1] mb-6">
            {pageData?.hero.heading ? pageData.hero.heading.split('\n').map((line, i) => (
              i === 0 ? <>{line}<br /></> : <>{line}</>
            )) : <>"Learn to Listen<br />with Your Hands"</>}
          </h1>
          <p class="font-sans text-stone text-lg leading-relaxed max-w-lg mb-10">
            {pageData?.hero.subheading ?? "Immersive trainings in deep, slow somatic bodywork — woven with presence, curiosity and care. A professional pathway rooted in fascia and deep tissue work that transforms how you touch and how you listen."}
          </p>
          <div class="flex flex-wrap gap-4">
            <ApplyButton text={pageData?.hero.cta_text ?? "Explore Trainings"} href={pageData?.hero.cta_href ?? "/dates"} />
            <a
              href={pageData?.hero.secondary_cta_href ?? "/about-the-work"}
              class="inline-flex items-center px-8 py-3 border border-forest text-forest rounded-btn font-medium hover:bg-forest hover:text-white transition-colors duration-200"
            >
              {pageData?.hero.secondary_cta_text ?? "About the Work"}
            </a>
          </div>
        </div>

        <!-- Image -->
        <div class="rounded-lg overflow-hidden">
          <img
            src={pageData?.hero.image ?? "/images/daniel-bodywork.jpg"}
            alt={pageData?.hero.imageAlt ?? "Daniel Wendt giving a deep somatic bodywork session"}
            class="w-full h-[500px] md:h-[600px] object-cover"
            fetchpriority="high"
          />
        </div>

      </div>
    </section>

    <StatsDivider />

    <!-- ===== 1b. INTRO TEXT (from Wix homepage) ===== -->
    <section class="py-12 md:py-16 px-6 md:px-12 bg-canvas">
      <div class="max-w-3xl mx-auto text-center space-y-8">
        {pageData?.sections?.find(s => s.id === 'intro')?.paragraphs.map((p) => (
          <p class="font-sans text-text-main text-lg md:text-xl leading-relaxed">{p}</p>
        ))}
        <div class="pt-4">
          <a href="/about-the-work" class="inline-flex items-center px-8 py-3 border border-forest text-forest rounded-btn font-medium hover:bg-forest hover:text-white transition-colors duration-200">
            Learn more about this work
          </a>
        </div>
      </div>
    </section>

    <!-- ===== 2. TESTIMONIAL DIVIDER — Ely, UK ===== -->
    {elyUK && (
      <TestimonialDivider
        quote={elyUK.quote}
        name={elyUK.name}
        location={elyUK.location}
        photo={elyUK.photo}

      />
    )}

    <!-- ===== 3. TRAINING PATHWAY ===== -->
    <section class="py-12 md:py-16 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto">
        <FadeIn>
        <p class="font-sans text-stone text-xs uppercase tracking-widest mb-4">{pageData?.training_pathway?.label}</p>
        <h2 class="font-serif text-3xl md:text-4xl text-text-main mb-12">{pageData?.training_pathway?.heading}</h2>
        </FadeIn>

        <div class="flex flex-col gap-16">

          {pageData?.training_pathway?.levels.map((level, i) => (
            <a
              href={level.href}
              class={`flex flex-col ${i % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'} rounded-card border border-stone/10 overflow-hidden hover:border-stone/30 hover:shadow-md transition-all duration-200 group bg-white`}
            >
              <div class="w-full md:w-[45%] shrink-0">
                <div class="aspect-[4/3] md:aspect-auto md:h-full overflow-hidden">
                  <img
                    src={level.image}
                    alt={level.imageAlt}
                    class="w-full h-full object-cover object-center group-hover:scale-[1.02] transition-transform duration-500"
                    loading="lazy"
                  />
                </div>
              </div>
              <div class="w-full md:w-[55%] p-8 md:p-10 flex flex-col justify-center">
                <span class="inline-block font-sans text-xs font-bold uppercase tracking-[0.15rem] text-forest bg-surface-lo px-3 py-1 rounded-btn mb-4 self-start">
                  {level.badge}
                </span>
                <h3 class="font-serif font-black text-text-main text-2xl md:text-3xl leading-tight mb-4 group-hover:text-forest transition-colors">
                  {level.heading}
                </h3>
                <p class="font-sans text-stone text-base leading-relaxed">
                  {level.description}
                </p>
                <span class="inline-flex items-center gap-2 font-sans text-forest font-medium text-sm mt-6 group-hover:gap-3 transition-all">
                  {level.cta_text}
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12"/>
                    <polyline points="12 5 19 12 12 19"/>
                  </svg>
                </span>
              </div>
            </a>
          ))}

        </div>
      </div>
    </section>

    <!-- ===== PARALLAX — after Training Pathway ===== -->
    <Parallax src={pageData?.parallax_1 ?? "/images/general/dan-outside-38.jpg"} height="50vh" />

    <!-- ===== 4. VIDEO INSIGHTS ===== -->
    <section class="py-12 md:py-16 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto">
        <h2 class="font-serif text-3xl md:text-4xl text-text-main mb-12 text-center">
          {pageData?.videos?.heading}
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

          {pageData?.videos?.items.map((video) => (
            <div>
              <div class="relative w-full aspect-video rounded-card overflow-hidden">
                <iframe
                  src={`https://www.youtube-nocookie.com/embed/${video.youtube_id}`}
                  title={pageData?.videos?.heading}
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                  class="absolute inset-0 w-full h-full"
                  loading="lazy"
                ></iframe>
              </div>
              <p class="font-sans text-stone text-sm mt-3 text-center">{video.caption}</p>
            </div>
          ))}

        </div>
      </div>
    </section>

    <StatsDivider />

    <!-- ===== 5. UPCOMING TRAININGS ===== -->
    <section class="py-12 md:py-16 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto">
        <FadeIn>
        <h2 class="font-serif text-3xl md:text-4xl text-text-main mb-12">{pageData?.upcoming_trainings?.heading ?? "Upcoming Trainings"}</h2>
        </FadeIn>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-10">
          {trainings.map(t => (
            <TrainingCard
              title={t.title}
              date={t.date}
              location={t.location}
              level={t.level}
              href={t.href}
              image={t.image}
            />
          ))}
        </div>

        <a href={pageData?.upcoming_trainings?.cta_href ?? "/dates"} class="font-sans text-forest font-medium hover:text-sage transition-colors inline-flex items-center gap-2">
          {pageData?.upcoming_trainings?.cta_text ?? "View all dates"}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
      </div>
    </section>

    <!-- ===== 6. TESTIMONIAL DIVIDER — Jane, USA ===== -->
    {janeUSA && (
      <TestimonialDivider
        quote={janeUSA.quote}
        name={janeUSA.name}
        location={janeUSA.location}
        photo={janeUSA.photo}

      />
    )}

    <!-- ===== PARALLAX — before About Teaser ===== -->
    <Parallax src={pageData?.parallax_2 ?? "/images/general/training-flyer-2.jpg"} height="40vh" position="top" />

    <!-- ===== 7. ABOUT TEASER ===== -->
    <section class="py-12 md:py-16 px-6 md:px-12 bg-canvas">
      <FadeIn>
      <div class="max-w-page mx-auto grid grid-cols-1 md:grid-cols-5 gap-12 items-center">

        <!-- Image — 2/5 -->
        <div class="md:col-span-2 rounded-card overflow-hidden">
          <img
            src={pageData?.about_teaser?.image ?? "/images/daniel-portrait.jpg"}
            alt={pageData?.about_teaser?.imageAlt ?? "Daniel Wendt"}
            class="w-full h-full object-cover"
          />
        </div>

        <!-- Text — 3/5 -->
        <div class="md:col-span-3">
          <p class="font-sans text-stone text-xs uppercase tracking-widest mb-4">{pageData?.about_teaser?.label}</p>
          <h2 class="font-serif text-3xl md:text-4xl text-text-main mb-2">{pageData?.about_teaser?.heading}</h2>
          <p class="font-sans text-forest text-sm font-medium uppercase tracking-widest mb-6">{pageData?.about_teaser?.title}</p>
          <p class="font-sans text-stone text-lg leading-relaxed mb-8">
            {pageData?.about_teaser?.bio}
          </p>
          <a href={pageData?.about_teaser?.cta_href ?? "/about-dan"} class="font-sans text-forest font-medium hover:text-sage transition-colors inline-flex items-center gap-2">
            {pageData?.about_teaser?.cta_text ?? "Read more"}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12 5 19 12 12 19"/>
            </svg>
          </a>
        </div>

      </div>
      </FadeIn>
    </section>

    <StatsDivider />

    <!-- ===== 8. CONTACT SECTION ===== -->
    <section class="py-8 md:py-12 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto text-center">
        <h2 class="font-serif text-3xl md:text-4xl text-text-main mb-4">{pageData?.contact?.heading}</h2>
        <p class="font-sans text-stone text-lg leading-relaxed max-w-xl mx-auto mb-10">
          {pageData?.contact?.subtext}
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <ApplyButton text={pageData?.contact?.cta_text ?? "Contact"} href={pageData?.contact?.cta_href ?? "/contact"} />
          <a
            href={`mailto:${pageData?.contact?.email ?? "danhealingarts@gmail.com"}`}
            class="inline-flex items-center px-8 py-3.5 border border-forest text-forest rounded-btn font-medium text-base hover:bg-forest hover:text-white transition-colors duration-200"
          >
            {pageData?.contact?.email ?? "danhealingarts@gmail.com"}
          </a>
        </div>
      </div>
    </section>

  </main>

  <!-- ===== 9. FOOTER ===== -->
  <Footer lang="en" />

</Layout>

