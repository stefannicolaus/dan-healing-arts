---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import TestimonialDivider from '../components/TestimonialDivider.astro';
import TextImageSection from '../components/TextImageSection.astro';
import ApplyButton from '../components/ApplyButton.astro';
import Parallax from '../components/Parallax.astro';
import FadeIn from '../components/FadeIn.astro';
import StatsDivider from '../components/StatsDivider.astro';
import { getRetreat, getTestimonials } from '../lib/queries';
import { imageUrl } from '../lib/sanity';

const allTestimonials = await getTestimonials();
const rebeccaCanada = allTestimonials.find((t: any) => t.name === 'Rebecca' && t.location?.includes('Canada'));
const lasseFinland = allTestimonials.find((t: any) => t.name === 'Lasse' && t.location?.includes('Finland'));
const lauraUK = allTestimonials.find((t: any) => t.name === 'Laura' && t.location?.includes('UK'));

const retreat = await getRetreat('spain');
---

<Layout
  lang="en"
  title={retreat?.page_title ?? "Spain — An Evolution of Sensitivity | Dan Healing Arts"}
  description={retreat?.page_description ?? "A 7-day Level 2 training in the Alpujarra mountains of southern Spain. Hidden Paradise retreat center, near Granada. 10–16 May, 2026."}
  canonicalPath="/spain"
  ogImage={retreat?.og_image ?? "/images/spain/hero.jpg"}
>
  <Nav lang="en" />

  <main>

    <!-- ===== 1. HERO ===== -->
    <FadeIn>
    <section class="pt-32 pb-24 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto">
        <TextImageSection image={imageUrl(retreat?.hero_image, "/images/spain/hero.jpg")} imageAlt="Hidden Paradise retreat center in the Alpujarra mountains of southern Spain" imagePosition="center">
          <p class="font-sans text-xs font-bold uppercase tracking-[0.15rem] text-forest mb-4">{retreat?.hero_badge ?? "Spain · Level 2"}</p>
          <h1 class="font-serif text-4xl md:text-5xl text-text-main mb-6 leading-tight">
            {retreat?.hero_heading ?? "An Evolution of Sensitivity"}
          </h1>
          <p class="font-sans text-stone text-lg italic mb-2">
            A Myofascial Somatic Liberation Training —{' '}
            <a href={retreat?.hero_cta_href ?? "/level-2"} class="text-forest hover:text-sage transition-colors underline underline-offset-4">
              {retreat?.hero_cta_text ?? "Level 2"}
            </a>
          </p>
          <p class="font-sans text-stone text-base mb-4">
            {retreat?.hero_dates ?? "Spain · 10 – 16 May, 2026"}
          </p>
          <p class="font-sans text-stone text-base italic mb-10">
            {retreat?.hero_subheading ?? "A 7-day immersive training deepening your practice in fascia-based bodywork and somatic sensitivity."}
          </p>
          <ApplyButton text="Get in Touch" />
        </TextImageSection>
      </div>
    </section>
    </FadeIn>

    <StatsDivider />

    <!-- ===== 2. VIDEO ===== -->
    <!-- TODO Daniel: YouTube-Video-ID einfügen und diesen Block aktivieren -->
    <!--
    <FadeIn>
    <section class="py-12 md:py-16 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto">
        <h2 class="font-serif text-3xl md:text-4xl text-text-main mb-10 text-center">
          Real moments from the Spain Training
        </h2>
        <div class="relative w-full max-w-3xl mx-auto aspect-video rounded-card overflow-hidden">
          <iframe
            src="https://www.youtube-nocookie.com/embed/VIDEO_ID_HERE"
            title="Myofascial Somatic Liberation — Bodywork Training Level 2, Spain"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            class="absolute inset-0 w-full h-full"
            loading="lazy"
          ></iframe>
        </div>
      </div>
    </section>
    </FadeIn>

    <StatsDivider />
    -->

    <!-- ===== 3–10. CONTENT SECTIONS ===== -->
    {retreat?.sections?.map((section) => (
      <>
        <FadeIn>
        <section class={`py-12 md:py-16 px-6 md:px-12 bg-canvas ${section.id === 'field_2' || section.id === 'venue_2' ? 'md:pt-6' : ''}`}>
          <div class="max-w-page mx-auto">
            <TextImageSection
              image={imageUrl(section.image, section.image)}
              imageAlt={section.imageAlt ?? ''}
              reversed={section.reversed ?? false}
              imagePosition={section.imagePosition ?? 'center'}
            >
              {section.heading && (
                <h2 class="font-serif text-3xl md:text-4xl text-text-main mb-6">{section.heading}</h2>
              )}
              <div class={`font-sans text-stone leading-relaxed space-y-4${section.show_apply_button ? ' mb-10' : ''}`}>
                {section.paragraphs.map((p) => <p>{p}</p>)}
              </div>
              {section.show_apply_button && <ApplyButton text="Get in Touch" />}
            </TextImageSection>
          </div>
        </section>
        </FadeIn>

        {/* Parallax after deepening section */}
        {section.id === 'deepening' && (
          <Parallax src="/images/spain/hidden-paradise-62.jpg" height="45vh" />
        )}

        {/* Testimonials after specific sections */}
        {section.id === 'experiential' && rebeccaCanada && (
          <TestimonialDivider
            quote={rebeccaCanada.quote}
            name={rebeccaCanada.name}
            location={rebeccaCanada.location}
            photo={rebeccaCanada.photo}
          />
        )}
        {section.id === 'field_2' && lasseFinland && (
          <TestimonialDivider
            quote={lasseFinland.quote}
            name={lasseFinland.name}
            location={lasseFinland.location}
            photo={lasseFinland.photo}
          />
        )}
        {section.id === 'nourished' && lauraUK && (
          <TestimonialDivider
            quote={lauraUK.quote}
            name={lauraUK.name}
            location={lauraUK.location}
            photo={lauraUK.photo}
          />
        )}

        {/* Parallax before venue */}
        {section.id === 'field_2' && (
          <Parallax src="/images/spain/hidden-paradise-36.jpg" height="45vh" />
        )}

        {/* StatsDividers after specific sections */}
        {(section.id === 'training_experience' || section.id === 'venue_2' || section.id === 'for_whom') && (
          <StatsDivider />
        )}
      </>
    ))}

    <StatsDivider />

    <!-- ===== WHAT YOU'LL RECEIVE ===== -->
    <FadeIn>
    <section class="py-12 md:py-16 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto">
        <TextImageSection
          image={retreat?.what_you_receive?.image ?? "/images/spain/hidden-paradise-36.jpg"}
          imageAlt={retreat?.what_you_receive?.imageAlt ?? "Hidden Paradise — mountain landscape, southern Spain"}
          reversed
          imagePosition={retreat?.what_you_receive?.imagePosition ?? 'center'}
        >
          <h2 class="font-serif text-3xl md:text-4xl text-text-main mb-8">
            {retreat?.what_you_receive?.heading ?? "What You'll Receive"}
          </h2>
          <ul class="font-sans text-stone leading-relaxed space-y-3 mb-10">
            {(retreat?.what_you_receive?.items ?? []).map((item) => (
              <li class="flex items-start gap-3">
                <span class="text-forest mt-1 shrink-0">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                </span>
                {item}
              </li>
            ))}
          </ul>
          <ApplyButton text="Get in Touch" />
        </TextImageSection>
      </div>
    </section>
    </FadeIn>

    <StatsDivider />

    <!-- ===== INTERESTED? (pricing placeholder) ===== -->
    <!-- TODO Daniel: Preise und Zimmeroptionen ergänzen wenn bestätigt -->
    <FadeIn>
    <section class="py-12 md:py-16 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto max-w-3xl">
        <h2 class="font-serif text-3xl md:text-4xl text-text-main mb-6">
          Interested?
        </h2>
        <div class="font-sans text-stone leading-relaxed space-y-4">
          <p>
            Details, pricing and accommodation options for the Spain training will be announced soon.
          </p>
          <p>
            If you're interested in joining or have questions, reach out directly — I'm happy to share more about what to expect and whether this training is a good fit for where you are in your practice.
          </p>
          <p class="italic">
            After your message, I'll personally respond with more details and next steps.
          </p>
        </div>
        <div class="mt-8 mb-4">
          <ApplyButton text="Get in Touch" />
        </div>
      </div>
    </section>
    </FadeIn>

    <StatsDivider />

    <!-- ===== CLOSING STATEMENT ===== -->
    <FadeIn>
    <section class="py-8 md:py-12 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto text-center max-w-3xl">
        <div class="font-serif italic text-text-main text-xl md:text-2xl leading-relaxed prose prose-stone max-w-none">
          <div set:html={retreat?.closing_quote ?? "This training is an invitation to go deeper — to listen with greater sensitivity, and to trust the intelligence that lives in your hands and in the body you meet. If you feel called, you're warmly welcome to join us."} />
        </div>
      </div>
    </section>
    </FadeIn>

  </main>

  <!-- ===== FOOTER ===== -->
  <Footer lang="en" />

</Layout>
