---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ApplyButton from '../components/ApplyButton.astro';
---

<Layout
  lang="en"
  title="Spain — Dan Healing Arts"
  description="An Evolution of Sensitivity — Level 2 training in the Alpujarra mountains of southern Spain, near Granada. 10–16 May, 2026."
  canonicalPath="/spain"
>
  <Nav lang="en" />

  <main>

    <!-- ===== 1. HERO ===== -->
    <section class="relative min-h-[60vh] flex items-center justify-center bg-surface-mid overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-b from-black/50 via-black/30 to-black/60"></div>
      <div class="relative z-10 text-center">
        <h1 class="font-serif text-5xl md:text-7xl text-white uppercase tracking-widest">
          SPAIN
        </h1>
      </div>
    </section>

    <!-- ===== 2. ANNOUNCEMENT ===== -->
    <section class="py-16 px-6 md:px-12 bg-canvas text-center">
      <div class="max-w-2xl mx-auto">
        <p class="font-sans text-xs font-bold uppercase tracking-[0.2rem] text-forest mb-4">
          Coming Soon
        </p>
        <h2 class="font-serif text-3xl md:text-4xl text-text-main mb-4">
          An Evolution of Sensitivity — Level 2
        </h2>
        <p class="font-sans text-stone text-base">
          10 – 16 May, 2026
        </p>
      </div>
    </section>

    <!-- ===== 3. LOCATION ===== -->
    <section class="py-24 px-6 md:px-12 bg-surface-lo">
      <div class="max-w-page mx-auto max-w-3xl">
        <h2 class="font-serif text-3xl md:text-4xl text-text-main mb-8">
          Hidden Paradise
        </h2>
        <div class="font-sans text-stone leading-relaxed space-y-4">
          <p>
            Hidden Paradise is a family-run retreat center nestled in the Alpujarra mountains of southern Spain, near Granada. Perched at over 1,000 meters above the Mediterranean, the views stretch all the way to Morocco.
          </p>
          <p>
            Completely off-grid, the center offers two pools, a wood-fired sauna, and two round, temple-like domed spaces for movement and sound work.
          </p>
          <p>
            A place where the land itself holds you — far from the noise, close to what matters.
          </p>
          <p>
            <a
              href="https://www.hiddenparadise.org"
              target="_blank"
              rel="noopener noreferrer"
              class="text-forest hover:text-sage transition-colors underline underline-offset-4"
            >
              www.hiddenparadise.org
            </a>
          </p>
        </div>
      </div>
    </section>

    <!-- ===== 4. CTA ===== -->
    <section class="py-24 px-6 md:px-12 bg-canvas text-center">
      <div class="max-w-2xl mx-auto">
        <p class="font-sans italic text-stone text-lg mb-8">
          Details and pricing will be announced soon. If you're interested, reach out directly.
        </p>
        <ApplyButton text="Get in Touch" />
      </div>
    </section>

  </main>

  <!-- ===== 5. FOOTER ===== -->
  <Footer lang="en" />

</Layout>
