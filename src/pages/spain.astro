---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import TestimonialDivider from '../components/TestimonialDivider.astro';
import TextImageSection from '../components/TextImageSection.astro';
import ApplyButton from '../components/ApplyButton.astro';
import Parallax from '../components/Parallax.astro';
import PhotoGallery from '../components/PhotoGallery.astro';
import FadeIn from '../components/FadeIn.astro';
import StatsDivider from '../components/StatsDivider.astro';

const allTestimonials = await getCollection('testimonials');
const rebeccaCanada = allTestimonials.find(t => t.id === 'rebecca-canada')?.data;
const lasseFinland = allTestimonials.find(t => t.id === 'lasse-finland')?.data;
const lauraUK = allTestimonials.find(t => t.id === 'laura-uk')?.data;
---

<Layout
  lang="en"
  title="Spain — An Evolution of Sensitivity | Dan Healing Arts"
  description="A 7-day Level 2 training in the Alpujarra mountains of southern Spain. Hidden Paradise retreat center, near Granada. 10–16 May, 2026."
  canonicalPath="/spain"
>
  <Nav lang="en" />

  <main>

    <!-- ===== 1. HERO ===== -->
    <FadeIn>
    <section class="pt-32 pb-24 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto">
        <TextImageSection image="/images/spain/hero.jpg" imageAlt="Hidden Paradise retreat center in the Alpujarra mountains of southern Spain">
          <p class="font-sans text-xs font-bold uppercase tracking-[0.15rem] text-forest mb-4">Spain · Level 2</p>
          <h1 class="font-serif text-4xl md:text-5xl text-text-main mb-6 leading-tight">
            An Evolution of Sensitivity
          </h1>
          <p class="font-sans text-stone text-lg italic mb-2">
            A Myofascial Somatic Liberation Training —{' '}
            <a href="/level-2" class="text-forest hover:text-sage transition-colors underline underline-offset-4">
              Level 2
            </a>
          </p>
          <p class="font-sans text-stone text-base mb-4">
            Spain · 10 – 16 May, 2026
          </p>
          <p class="font-sans text-stone text-base italic mb-10">
            A 7-day immersive training deepening your practice in fascia-based bodywork and somatic sensitivity.
          </p>
          <ApplyButton text="Get in Touch" />
        </TextImageSection>
      </div>
    </section>
    </FadeIn>

    <StatsDivider />

    <!-- ===== 2. DEEPENING YOUR PRACTICE ===== -->
    <FadeIn>
    <section class="py-12 md:py-16 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto">
        <TextImageSection image="/images/spain/dsc2233.jpg" imageAlt="Practitioners in deep bodywork training at Hidden Paradise, Spain">
          <h2 class="font-serif text-3xl md:text-4xl text-text-main mb-6">
            Deepening Your Practice
          </h2>
          <div class="font-sans text-stone leading-relaxed space-y-4">
            <p>
              <strong class="text-text-main">An Evolution of Sensitivity</strong> is an immersive{' '}
              <strong class="text-text-main">advanced training in fascia-based bodywork.</strong>
              {' '}It offers the Level 2 training program of the Myofascial Somatic Liberation pathway.
            </p>
            <p>
              → <em><a href="/level-2" class="text-forest hover:text-sage transition-colors underline underline-offset-4">Learn more about the full Level 2 training</a></em>
            </p>
            <p>
              Building on the foundations of Level 1, this training takes you deeper — into subtler layers of the fascia, more refined touch, and a more intimate relationship with the body's nervous system and emotional landscape.
            </p>
            <p>
              Over the course of the week, you will expand your range as a practitioner, learning how to hold more complexity, respond with greater nuance, and guide sessions with increased confidence and depth.
            </p>
            <p>
              As in Level 1, you will both give and receive sessions each day — deepening not only your skills but your own embodied understanding of what this work can offer.
            </p>
          </div>
        </TextImageSection>
      </div>
    </section>
    </FadeIn>

    <!-- ===== PARALLAX between sections ===== -->
    <Parallax src="/images/spain/hidden-paradise-62.jpg" height="45vh" />

    <!-- ===== 3. THE TRAINING EXPERIENCE ===== -->
    <FadeIn>
    <section class="py-12 md:py-16 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto">
        <TextImageSection image="/images/spain/dsc2128.jpg" imageAlt="Training experience at Hidden Paradise — group bodywork practice in Spain" reversed>
          <h2 class="font-serif text-3xl md:text-4xl text-text-main mb-6">
            The Training Experience
          </h2>
          <div class="font-sans text-stone leading-relaxed space-y-4">
            <p>
              This training invites you to slow down, listen deeply, and enter the landscape of the body with care and precision.
            </p>
            <p>
              You'll refine your ability to offer full-body touch that is structurally and anatomically grounded, drawing from advanced myofascial and deep tissue techniques while remaining attuned to the nervous system and emotional responses that unfold through touch.
            </p>
            <p>
              Alongside these hands-on techniques, the training cultivates the subtle skills of presence, listening and energetic awareness that allow sessions to become deeply restorative and transformative.
            </p>
            <p>
              During this week you will develop{' '}
              <strong class="text-text-main">both the advanced practical skills and the embodied sensitivity needed to take your work to the next level.</strong>
            </p>
          </div>
        </TextImageSection>
      </div>
    </section>
    </FadeIn>

    <StatsDivider />

    <!-- ===== 4. EXPERIENTIAL LEARNING ===== -->
    <FadeIn>
    <section class="py-12 md:py-16 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto">
        <TextImageSection>
          <div class="font-sans text-stone leading-relaxed space-y-4">
            <p>
              The learning is highly experiential and hands-on.
              Each day, you will observe, give, and receive two full bodywork sessions, giving you extensive hands-on practice.
            </p>
            <p>
              Through this rhythm of practicing and being worked on, your system becomes more receptive and your hands gradually become more refined and precise, learning to respond to increasingly subtle layers of what they meet in the body.
            </p>
            <p>
              Daily practices such as yoga, meditation, breathwork, voice work and ceremonial spaces support integration, allowing what moves through the body to land gently and sustainably.
            </p>
          </div>
          <div class="mt-8 mb-4">
            <ApplyButton text="Get in Touch" />
          </div>
        </TextImageSection>
      </div>
    </section>
    </FadeIn>

    <!-- ===== 5. TESTIMONIAL — REBECCA, CANADA ===== -->
    {rebeccaCanada && (
      <TestimonialDivider
        quote={rebeccaCanada.quote}
        name={rebeccaCanada.name}
        location={rebeccaCanada.location}
        photo={rebeccaCanada.photo}
      />
    )}

    <!-- ===== 6. THE FIELD WE PRACTICE IN ===== -->
    <FadeIn>
    <section class="py-12 md:py-16 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto max-w-3xl">
        <h2 class="font-serif text-3xl md:text-4xl text-text-main mb-8">
          The Field We Practice In
        </h2>
        <div class="font-sans text-stone leading-relaxed space-y-4">
          <p>
            This training takes place within a warm, grounded and playful group field, where learning happens not only through instruction, but through direct experience — through touch, presence and the body's natural capacity to release and reorganize.
          </p>
          <p>
            It is not only about learning how to touch, but also about remembering how to listen.
          </p>
          <p>
            Anatomy is explored directly through touch, learning on the body rather than only through theory. As you work with the structure of the fascia, anatomical understanding becomes increasingly tangible and grounded in your hands.
          </p>
          <p>
            In this relational space, connection deepens — with your own body, with others, and with the deeper intelligence that lives beneath the surface.
          </p>
          <p>
            More than simply a training, the week becomes a gradual spiraling process of opening, unwinding and empowerment.
          </p>
        </div>
      </div>
    </section>
    </FadeIn>

    <!-- ===== 7. TESTIMONIAL — LASSE, FINLAND ===== -->
    {lasseFinland && (
      <TestimonialDivider
        quote={lasseFinland.quote}
        name={lasseFinland.name}
        location={lasseFinland.location}
        photo={lasseFinland.photo}
      />
    )}

    <!-- ===== PARALLAX before venue ===== -->
    <Parallax src="/images/spain/hidden-paradise-36.jpg" height="45vh" />

    <!-- ===== 8. THE SPACE THAT HOLDS THE WORK (VENUE) ===== -->
    <FadeIn>
    <section class="py-12 md:py-16 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto">
        <h2 class="font-serif text-3xl md:text-4xl text-text-main mb-10">
          The Space That Holds the Work
        </h2>

        <div class="mb-12">
          <PhotoGallery
            images={[
              { src: "/images/spain/hidden-paradise-62.jpg", alt: "Hidden Paradise retreat center view from above" },
              { src: "/images/spain/dsc08074.jpg", alt: "Practice space at Hidden Paradise Spain" },
              { src: "/images/spain/dsc08001.jpg", alt: "Natural surroundings at Hidden Paradise retreat" },
              { src: "/images/spain/dsc2128.jpg", alt: "Mountain landscape at Hidden Paradise, Alpujarra Spain" },
            ]}
            caption="Hidden Paradise — Alpujarra mountains, southern Spain"
          />
        </div>

        <div class="max-w-3xl font-sans text-stone leading-relaxed space-y-4">
          <p>
            Hidden Paradise is a family-run retreat center nestled in the Alpujarra mountains of southern Spain, near Granada.
          </p>
          <p>
            Perched at over 1,000 meters above the Mediterranean, the views stretch all the way to Morocco — and the sense of altitude, silence and distance from ordinary life is immediate upon arrival.
          </p>
          <p>
            Completely off-grid, the center offers two pools, a wood-fired sauna, and two round, temple-like domed spaces designed specifically for movement and sound work. These circular practice spaces create a naturally sacred and focused container for the depth of work we do.
          </p>
          <p>
            The land itself invites surrender. Far from the noise of modern life, it becomes easier to slow down, go inward, and let the work move through you.
          </p>
          <p>
            <a href="https://www.hiddenparadise.org" target="_blank" rel="noopener noreferrer" class="text-forest hover:text-sage transition-colors underline underline-offset-4">
              Location: www.hiddenparadise.org
            </a>
          </p>
          <p>
            Between sessions, there is space to walk, breathe, swim, integrate, and simply be — allowing the work to settle beyond the mat and table.
          </p>
        </div>
      </div>
    </section>
    </FadeIn>

    <StatsDivider />

    <!-- ===== 9. WHO IS THIS TRAINING FOR ===== -->
    <FadeIn>
    <section class="py-12 md:py-16 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto max-w-3xl">
        <h2 class="font-serif text-3xl md:text-4xl text-text-main mb-8">
          Who Is This Training For
        </h2>
        <div class="font-sans text-stone leading-relaxed space-y-4">
          <p>
            This training is designed for practitioners who have already completed Level 1 of the Myofascial Somatic Liberation pathway, or who carry equivalent experience in body-based therapeutic work.
          </p>
          <p>
            It is for those who are ready to move beyond the foundational techniques — into greater subtlety, complexity, and relational depth in their practice.
          </p>
          <p>
            If you are drawn to working more deeply with the emotional and nervous system dimensions of bodywork, and if you value learning through direct experience rather than theory alone, this training offers the next step on your path.
          </p>
          <p>
            <strong class="text-text-main">Please note: This training is designed to touch deeply and to be deeply touched. A respectful presence and clear boundaries are essential.</strong>
          </p>
        </div>
        <div class="mt-8 mb-4">
          <ApplyButton text="Get in Touch" />
        </div>
      </div>
    </section>
    </FadeIn>

    <!-- ===== 10. TESTIMONIAL — LAURA, UK ===== -->
    {lauraUK && (
      <TestimonialDivider
        quote={lauraUK.quote}
        name={lauraUK.name}
        location={lauraUK.location}
        photo={lauraUK.photo}
      />
    )}

    <!-- ===== 11. INTERESTED? (CTA instead of pricing) ===== -->
    <FadeIn>
    <section class="py-12 md:py-16 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto max-w-3xl">
        <h2 class="font-serif text-3xl md:text-4xl text-text-main mb-6">
          Interested?
        </h2>
        <div class="font-sans text-stone leading-relaxed space-y-4">
          <p>
            Details, pricing and accommodation options for the Spain training will be announced soon.
          </p>
          <p>
            If you're interested in joining or have questions, reach out directly — I'm happy to share more about what to expect and whether this training is a good fit for where you are in your practice.
          </p>
          <p class="italic">
            After your message, I'll personally respond with more details and next steps.
          </p>
        </div>
        <div class="mt-8 mb-4">
          <ApplyButton text="Get in Touch" />
        </div>
      </div>
    </section>
    </FadeIn>

    <StatsDivider />

    <!-- ===== 12. PRACTICAL DETAILS ===== -->
    <FadeIn>
    <section class="py-12 md:py-16 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto max-w-3xl">
        <h2 class="font-serif text-3xl md:text-4xl text-text-main mb-10">
          Practical Details
        </h2>
        <dl class="font-sans space-y-6">
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-2 border-b border-stone/10 pb-6">
            <dt class="text-stone text-xs font-bold uppercase tracking-[0.15rem]">Dates</dt>
            <dd class="sm:col-span-2 text-text-main leading-relaxed">
              May 10 – 16, 2026
            </dd>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-2 border-b border-stone/10 pb-6">
            <dt class="text-stone text-xs font-bold uppercase tracking-[0.15rem]">Location</dt>
            <dd class="sm:col-span-2 text-text-main leading-relaxed">
              Hidden Paradise, Alpujarra mountains, southern Spain<br />
              Near Granada
            </dd>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-2 border-b border-stone/10 pb-6">
            <dt class="text-stone text-xs font-bold uppercase tracking-[0.15rem]">Level</dt>
            <dd class="sm:col-span-2 text-text-main leading-relaxed">
              Level 2 — prerequisite: Level 1 or equivalent experience
            </dd>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-2">
            <dt class="text-stone text-xs font-bold uppercase tracking-[0.15rem]">More Info</dt>
            <dd class="sm:col-span-2 text-text-main leading-relaxed">
              Detailed information on pricing, accommodation and schedule will be shared after registration.
            </dd>
          </div>
        </dl>
      </div>
    </section>
    </FadeIn>

    <StatsDivider />

    <!-- ===== 13. CLOSING STATEMENT ===== -->
    <FadeIn>
    <section class="py-8 md:py-12 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto text-center max-w-3xl">
        <p class="font-serif italic text-text-main text-xl md:text-2xl leading-relaxed">
          This training is an invitation to go deeper — to listen with greater sensitivity, and to trust the intelligence that lives in your hands and in the body you meet. If you feel called, you're warmly welcome to join us.
        </p>
      </div>
    </section>
    </FadeIn>

  </main>

  <!-- ===== FOOTER ===== -->
  <Footer lang="en" />

</Layout>
