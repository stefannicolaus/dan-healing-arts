---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Parallax from '../components/Parallax.astro';
---

<Layout
  lang="en"
  title="Contact — Dan Healing Arts"
  description="Get in touch with Daniel Wendt — apply for a training, ask a question, or simply connect."
  canonicalPath="/contact"
>
  <Nav lang="en" />

  <main>

    <!-- ===== HERO PARALLAX ===== -->
    <Parallax src="/images/general/dan-hands.png" height="40vh" />

    <!-- ===== HEADER ===== -->
    <section class="pt-32 pb-16 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto max-w-2xl">
        <h1 class="font-serif text-4xl md:text-5xl text-text-main mb-6 leading-tight">
          Get in Touch
        </h1>
        <p class="font-sans text-stone text-lg leading-relaxed">
          Whether you'd like to apply for a training, ask a question, or simply connect — I'd love to hear from you.
        </p>
      </div>
    </section>

    <!-- ===== FORM ===== -->
    <section class="pb-24 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto grid grid-cols-1 md:grid-cols-2 gap-16 max-w-4xl">

        <!-- Contact form -->
        <form
          action="mailto:danhealingarts@gmail.com"
          method="post"
          enctype="text/plain"
          class="space-y-6"
        >
          <div>
            <label for="name" class="block font-sans text-sm font-medium text-text-main mb-2">
              Name <span class="text-forest">*</span>
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full font-sans text-stone bg-surface-lo border border-stone/15 rounded-btn px-4 py-3 focus:outline-none focus:border-forest transition-colors"
              placeholder="Your name"
            />
          </div>

          <div>
            <label for="email" class="block font-sans text-sm font-medium text-text-main mb-2">
              Email <span class="text-forest">*</span>
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full font-sans text-stone bg-surface-lo border border-stone/15 rounded-btn px-4 py-3 focus:outline-none focus:border-forest transition-colors"
              placeholder="your@email.com"
            />
          </div>

          <div>
            <label for="interest" class="block font-sans text-sm font-medium text-text-main mb-2">
              What are you interested in?
            </label>
            <select
              id="interest"
              name="interest"
              class="w-full font-sans text-stone bg-surface-lo border border-stone/15 rounded-btn px-4 py-3 focus:outline-none focus:border-forest transition-colors appearance-none"
            >
              <option value="">Please select...</option>
              <option value="Level 1 — Portugal">Level 1 — Portugal</option>
              <option value="Level 1 — Mazunte">Level 1 — Mazunte</option>
              <option value="Level 2 — Spain">Level 2 — Spain</option>
              <option value="Zürich Weekend Modules">Zürich Weekend Modules</option>
              <option value="Tulum">Tulum</option>
              <option value="Private Session">Private Session</option>
              <option value="Other">Other</option>
            </select>
          </div>

          <div>
            <label for="message" class="block font-sans text-sm font-medium text-text-main mb-2">
              Message <span class="text-forest">*</span>
            </label>
            <textarea
              id="message"
              name="message"
              required
              rows="6"
              class="w-full font-sans text-stone bg-surface-lo border border-stone/15 rounded-btn px-4 py-3 focus:outline-none focus:border-forest transition-colors resize-none"
              placeholder="Tell me a bit about yourself and what draws you to this work..."
            ></textarea>
          </div>

          <button
            type="submit"
            class="inline-block font-sans font-semibold text-sm tracking-wide bg-forest text-white hover:bg-sage px-8 py-4 rounded-btn transition-colors duration-200"
          >
            Send Message
          </button>
        </form>

        <!-- Direct contact -->
        <div class="pt-2">
          <h2 class="font-serif text-2xl text-text-main mb-8">Direct Contact</h2>

          <div class="space-y-6">
            <div>
              <p class="font-sans text-xs font-bold uppercase tracking-[0.15rem] text-forest mb-2">Email</p>
              <a
                href="mailto:danhealingarts@gmail.com"
                class="font-sans text-stone hover:text-text-main transition-colors"
              >
                danhealingarts@gmail.com
              </a>
            </div>

            <div>
              <p class="font-sans text-xs font-bold uppercase tracking-[0.15rem] text-forest mb-2">Instagram</p>
              <a
                href="https://www.instagram.com/dan.healing.arts"
                target="_blank"
                rel="noopener noreferrer"
                class="font-sans text-stone hover:text-text-main transition-colors"
              >
                @dan.healing.arts
              </a>
            </div>

            <div class="pt-4 border-t border-stone/10">
              <p class="font-sans text-stone text-sm leading-relaxed">
                I typically respond within 1–2 business days. For urgent questions about an upcoming training, feel free to reach out directly on Instagram.
              </p>
            </div>
          </div>
        </div>

      </div>
    </section>

  </main>

  <Footer lang="en" />

</Layout>
