---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import TestimonialDivider from '../components/TestimonialDivider.astro';
import TextImageSection from '../components/TextImageSection.astro';
import PhotoGallery from '../components/PhotoGallery.astro';
import PricingCard from '../components/PricingCard.astro';
import ApplyButton from '../components/ApplyButton.astro';
import FadeIn from '../components/FadeIn.astro';
import StatsDivider from '../components/StatsDivider.astro';
import { getRetreat, getTestimonials } from '../lib/queries';
import { imageUrl } from '../lib/sanity';

const allTestimonials = await getTestimonials();
const rebeccaCanada = allTestimonials.find((t: any) => t.name === 'Rebecca' && t.location?.includes('Canada'));
const lasseFinland = allTestimonials.find((t: any) => t.name === 'Lasse' && t.location?.includes('Finland'));
const lauraUK = allTestimonials.find((t: any) => t.name === 'Laura' && t.location?.includes('Mazunte'));

const retreat = await getRetreat('mazunte');
---

<Layout
  lang="en"
  title={retreat?.page_title ?? "Mazunte Retreat — The Essence of Deep Touch | Dan Healing Arts"}
  description={retreat?.page_description ?? "A 7-day immersive training in fascia release, deep tissue massage and nervous system attunement. Mazunte, Mexico, 24–30 January 2027."}
  canonicalPath="/mazunte"
  ogImage={retreat?.og_image ?? "/images/mazunte/hero.jpg"}
>
  <Nav lang="en" />

  <main>

    <!-- ===== 1. HERO ===== -->
    <FadeIn>
    <section class="pt-32 pb-24 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto">
        <TextImageSection image={imageUrl(retreat?.hero_image, "/images/mazunte/hero.jpg")} imageAlt="Mazunte retreat — The Essence of Deep Touch" imagePosition="center">
          <p class="font-sans text-xs font-bold uppercase tracking-[0.15rem] text-forest mb-4">{retreat?.hero_badge ?? "Mazunte, Mexico · Level 1"}</p>
          <h1 class="font-serif text-4xl md:text-5xl text-text-main mb-6 leading-tight">
            {retreat?.hero_heading ?? "The Essence of Deep Touch"}
          </h1>
          <p class="font-sans text-stone text-lg italic mb-2">
            A Myofascial Somatic Liberation Training —{' '}
            <a href={retreat?.hero_cta_href ?? "/level-1"} class="text-forest hover:text-sage transition-colors underline underline-offset-4">
              {retreat?.hero_cta_text ?? "Level 1"}
            </a>
          </p>
          <p class="font-sans text-stone text-base mb-4">
            {retreat?.hero_dates ?? "Mexico · 24 – 30 January, 2027"}
          </p>
          <p class="font-sans text-stone text-base italic mb-10">
            {retreat?.hero_subheading ?? "A 7-day immersive training in fascia release, deep tissue massage and nervous system attunement."}
          </p>
          <ApplyButton />
        </TextImageSection>
      </div>
    </section>
    </FadeIn>

    <StatsDivider />

    <!-- ===== 2. VIDEO ===== -->
    <FadeIn>
    <section class="py-12 md:py-16 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto">
        <h2 class="font-serif text-3xl md:text-4xl text-text-main mb-10 text-center">
          {retreat?.video?.title ?? "Real moments from the Mazunte Training"}
        </h2>
        <div class="relative w-full max-w-3xl mx-auto aspect-video rounded-card overflow-hidden">
          <iframe
            src={`https://www.youtube-nocookie.com/embed/${retreat?.video?.youtube_id ?? "mB88cuuMA84"}`}
            title="Myofascial Somatic Liberation — Bodywork Training Level 1, Mazunte"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            class="absolute inset-0 w-full h-full"
            loading="lazy"
          ></iframe>
        </div>
      </div>
    </section>
    </FadeIn>

    <StatsDivider />

    <!-- ===== 3–10. CONTENT SECTIONS ===== -->
    {retreat?.sections?.map((section, index) => (
      <>
        <FadeIn>
        <section class={`py-12 md:py-16 px-6 md:px-12 bg-canvas ${section.id === 'field_2' || section.id === 'venue_2' ? 'md:pt-6' : ''}`}>
          <div class="max-w-page mx-auto">
            <TextImageSection
              image={imageUrl(section.image, section.image)}
              imageAlt={section.imageAlt ?? ''}
              reversed={section.reversed ?? false}
              imagePosition={section.imagePosition ?? 'center'}
            >
              {section.heading && (
                <h2 class="font-serif text-3xl md:text-4xl text-text-main mb-6">{section.heading}</h2>
              )}
              <div class={`font-sans text-stone leading-relaxed space-y-4${section.show_apply_button ? ' mb-10' : ''}`}>
                {section.paragraphs.map((p) => <p>{p}</p>)}
              </div>
              {section.show_apply_button && <ApplyButton />}
            </TextImageSection>
          </div>
        </section>
        </FadeIn>

        {/* Testimonials after specific sections */}
        {section.id === 'experiential' && rebeccaCanada && (
          <TestimonialDivider
            quote={rebeccaCanada.quote}
            name={rebeccaCanada.name}
            location={rebeccaCanada.location}
            photo={rebeccaCanada.photo}
          />
        )}
        {section.id === 'field_2' && lasseFinland && (
          <TestimonialDivider
            quote={lasseFinland.quote}
            name={lasseFinland.name}
            location={lasseFinland.location}
            photo={lasseFinland.photo}
          />
        )}
        {section.id === 'nourished' && lauraUK && (
          <TestimonialDivider
            quote={lauraUK.quote}
            name={lauraUK.name}
            location={lauraUK.location}
            photo={lauraUK.photo}
          />
        )}

        {/* StatsDividers after specific sections */}
        {(section.id === 'training_experience' || section.id === 'venue_2' || section.id === 'for_whom') && (
          <StatsDivider />
        )}
      </>
    ))}

    <StatsDivider />

    <!-- ===== WHAT YOU'LL RECEIVE ===== -->
    <FadeIn>
    <section class="py-12 md:py-16 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto">
        <TextImageSection
          image={retreat?.what_you_receive?.image ?? "/images/mazunte/group-photo.jpg"}
          imageAlt={retreat?.what_you_receive?.imageAlt ?? "Mazunte training group"}
          reversed
          imagePosition={retreat?.what_you_receive?.imagePosition ?? 'center'}
        >
          <h2 class="font-serif text-3xl md:text-4xl text-text-main mb-8">
            {retreat?.what_you_receive?.heading ?? "What You'll Receive"}
          </h2>
          <ul class="font-sans text-stone leading-relaxed space-y-3 mb-10">
            {(retreat?.what_you_receive?.items ?? []).map((item) => (
              <li class="flex items-start gap-3">
                <span class="text-forest mt-1 shrink-0">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                </span>
                {item}
              </li>
            ))}
          </ul>
          <ApplyButton />
        </TextImageSection>
      </div>
    </section>
    </FadeIn>

    <StatsDivider />

    <!-- ===== PRICING ===== -->
    <FadeIn>
    <section class="py-12 md:py-16 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto">
        <h2 class="font-serif text-3xl md:text-4xl text-text-main mb-6">
          {retreat?.pricing_heading ?? "Your Stay at Bliss Haven"}
        </h2>

        <!-- Pricing Cards Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 grid-rows-[auto_auto_1fr_auto] gap-6 mb-10">
          {(retreat?.pricing_cards ?? []).map((card: any) => (
            <PricingCard
              title={card.title}
              image={imageUrl(card.image, '')}
              earlyPrice={card.early_price}
              earlyLabel={card.early_label}
              earlyDeadline={card.early_deadline}
              regularPrice={card.regular_price}
              regularLabel={card.regular_label}
              currency={card.currency}
            />
          ))}
        </div>

        <dl class="font-sans text-sm space-y-3 mt-8 mb-6">
          <div class="flex gap-6">
            <dt class="text-stone font-bold uppercase tracking-[0.12rem] text-xs w-28 shrink-0 pt-0.5">Certification</dt>
            <dd class="text-text-main">Level 1 Training Certificate upon full participation</dd>
          </div>
          <div class="flex gap-6">
            <dt class="text-stone font-bold uppercase tracking-[0.12rem] text-xs w-28 shrink-0 pt-0.5">Payment</dt>
            <dd class="text-text-main">Deposit required, cancellation terms during booking</dd>
          </div>
        </dl>

        <p class="font-sans text-stone text-base">
          {retreat?.pricing?.closing ?? "Still unsure which option is right for you? Feel free to reach out with any questions."}{' '}
          → <a href="/contact" class="text-forest hover:text-sage transition-colors underline underline-offset-4">Get in touch</a>
        </p>
      </div>
    </section>
    </FadeIn>

    <StatsDivider />

    <!-- ===== CLOSING STATEMENT ===== -->
    <FadeIn>
    <section class="py-8 md:py-12 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto text-center max-w-3xl">
        <div class="font-serif italic text-text-main text-xl md:text-2xl leading-relaxed prose prose-stone max-w-none">
          <div set:html={retreat?.closing_quote ?? "This training is an invitation to slow down, to listen, and to reconnect with the intelligence of touch - in yourself and in others. If you feel called, you're warmly welcome to join us."} />
        </div>
      </div>
    </section>
    </FadeIn>

  </main>

  <!-- ===== FOOTER ===== -->
  <Footer lang="en" />

</Layout>
