---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import ZurichHero from '../components/ZurichHero.astro';
import ZurichMethode from '../components/ZurichMethode.astro';
import ZurichWasEntwickelst from '../components/ZurichWasEntwickelst.astro';
import ZurichErfahrungsraum from '../components/ZurichErfahrungsraum.astro';
import ZurichModule from '../components/ZurichModule.astro';
import ZurichTestimonials from '../components/ZurichTestimonials.astro';
import ZurichUeberDaniel from '../components/ZurichUeberDaniel.astro';
import ZurichKontakt from '../components/ZurichKontakt.astro';
import Parallax from '../components/Parallax.astro';
import StatsDivider from '../components/StatsDivider.astro';
import Footer from '../components/Footer.astro';
import FadeIn from '../components/FadeIn.astro';
import TestimonialDivider from '../components/TestimonialDivider.astro';
import YouTubeEmbed from '../components/YouTubeEmbed.astro';
import { getCollection, getEntry } from 'astro:content';

const allTestimonials = (await getCollection('testimonials')).map(t => t.data);
const nicoUSA = allTestimonials.find(t => t.name === 'Nico Akiba' && t.location?.includes('USA'));
const ilincaGermany = allTestimonials.find(t => t.name === 'Ilinca' && t.location?.includes('Germany'));

const heroData = (await getEntry('hero', 'zurich'))?.data;
const methode = (await getEntry('zurichSektionen', 'methode'))?.data;
const entwickelst = (await getEntry('zurichSektionen', 'entwickelst'))?.data;
const erfahrungsraum = (await getEntry('zurichSektionen', 'erfahrungsraum'))?.data;
const ueber = (await getEntry('zurichSektionen', 'ueber'))?.data;

const heroBild = '/images/general/dan-outside-38.jpg';
---

<Layout
  lang="de"
  title="Somatische Tiefenmassage & Faszien Release — Wochenendkurse Zürich | Dan Healing Arts"
  description="Lerne präzise Faszienarbeit mit somatischer Präsenz. 4 Wochenendkurse in Zürich mit Daniel Wendt. Einzeln buchbar, je 420 CHF."
  canonicalPath="/"
>
  <Nav lang="de" />
  <main>
    <ZurichHero
      headline={heroData?.headline ?? 'Lerne, mit deinen Händen zu hören.'}
      subtext={heroData?.subtext ?? ''}
      cta_text={heroData?.cta_text ?? 'Jetzt anmelden'}
      cta_link={heroData?.cta_link ?? '/contact'}
      bild={heroBild}
      bildAlt={heroData?.bildAlt ?? "Daniel Wendt — Dan Healing Arts"}
    />
    <StatsDivider />
    <FadeIn>
      <ZurichMethode
        label={methode?.label}
        heading={methode?.heading}
        paragraphs={methode?.paragraphs ?? []}
        highlight={methode?.highlight}
      />
    </FadeIn>
    <Parallax src="/images/parallax-1-v2.jpg" height="50vh" />
    <FadeIn>
      <ZurichWasEntwickelst
        label={entwickelst?.label}
        heading={entwickelst?.heading}
        paragraphs={entwickelst?.paragraphs ?? []}
        highlight={entwickelst?.highlight}
        image={entwickelst?.image}
        imageAlt={entwickelst?.imageAlt ?? ''}
      />
    </FadeIn>
    <FadeIn>
      <ZurichErfahrungsraum
        label={erfahrungsraum?.label}
        heading={erfahrungsraum?.heading}
        paragraphs={erfahrungsraum?.paragraphs ?? []}
        highlight={erfahrungsraum?.highlight}
        image={erfahrungsraum?.image}
        imageAlt={erfahrungsraum?.imageAlt ?? ''}
      />
    </FadeIn>
    <FadeIn><ZurichModule /></FadeIn>
    <ZurichTestimonials />
    <StatsDivider />
    <FadeIn>
      <ZurichUeberDaniel
        heading={ueber?.heading}
        paragraphs={ueber?.paragraphs ?? []}
        stats={ueber?.stats}
        image={ueber?.image}
      />
    </FadeIn>
    <Parallax src="/images/parallax-2-v2.jpg" height="70vh" />
    <FadeIn><ZurichKontakt /></FadeIn>
  </main>
  <Footer lang="de" />
</Layout>
