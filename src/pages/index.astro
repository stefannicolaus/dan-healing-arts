---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Methode from '../components/Methode.astro';
import Parallax from '../components/Parallax.astro';
import MarqueeDivider from '../components/MarqueeDivider.astro';
import FuerWen from '../components/FuerWen.astro';
import Module from '../components/Module.astro';
import Testimonials from '../components/Testimonials.astro';
import UeberDaniel from '../components/UeberDaniel.astro';
import Kontakt from '../components/Kontakt.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Nav />
  <main>
    <Hero />
    <MarqueeDivider />
    <Methode />
    <Parallax src="/images/parallax-1.jpg" height="50vh" />
    <FuerWen />
    <Module />
    <Testimonials />
    <UeberDaniel />
    <Parallax src="/images/parallax-2.jpg" height="50vh" />
    <Kontakt />
  </main>
  <Footer />
</Layout>
