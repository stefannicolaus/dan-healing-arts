---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import TestimonialDivider from '../components/TestimonialDivider.astro';
import TrainingCard from '../components/TrainingCard.astro';
import ApplyButton from '../components/ApplyButton.astro';
import Parallax from '../components/Parallax.astro';
import TextImageSection from '../components/TextImageSection.astro';
import FadeIn from '../components/FadeIn.astro';
import StatsDivider from '../components/StatsDivider.astro';

const allTestimonials = await getCollection('testimonials');
const jeremyUSA = allTestimonials.find(t => t.id === 'jeremy-usa')?.data;
const robinUSA = allTestimonials.find(t => t.id === 'robin-usa')?.data;
const samUSA = allTestimonials.find(t => t.id === 'sam-usa')?.data;

const elements = [
  {
    element: 'Earth',
    emotion: 'Fear',
    // Two mountain peaks with a gentle curved horizon
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
      <path d="M3 32 L14 11 L21 21 L30 7 L37 32"/>
      <path d="M3 32 C13 29 27 29 37 32"/>
    </svg>`,
  },
  {
    element: 'Water',
    emotion: 'Sadness',
    // Teardrop with a delicate inner highlight arc
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
      <path d="M20 5 C20 5 9 19 9 26 A11 11 0 0 0 31 26 C31 19 20 5 20 5"/>
      <path d="M14 22 C13 25 14 28 17 29"/>
    </svg>`,
  },
  {
    element: 'Fire',
    emotion: 'Anger',
    // Single smooth flame with inner soul curve
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
      <path d="M20 34 C12 34 7 27 7 21 C7 14 13 8 16 4 C16 4 16 13 20 16 C22 11 24 6 24 6 C28 12 33 17 33 22 C33 29 27 34 20 34"/>
      <path d="M20 28 C16 28 15 24 15 22 C15 19 17 17 18 15 C18 15 18 19 20 20 C21 18 22 16 22 16 C24 18 25 21 25 22 C25 25 23 28 20 28"/>
    </svg>`,
  },
  {
    element: 'Air',
    emotion: 'Joy',
    // Breath spiral — one continuous inward curve
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
      <path d="M34 12 C34 7 30 5 26 5 C19 5 13 11 13 18 C13 23 16 26 21 26 C24 26 26 24 26 21 C26 19 24 17 22 17 C20 17 19 19 20 21"/>
    </svg>`,
  },
  {
    element: 'Space',
    emotion: 'Shame',
    // Cosmic circle with constellation — center orb + scattered stars
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="20" cy="20" r="15"/>
      <circle cx="20" cy="20" r="2.5" fill="currentColor" stroke="none"/>
      <circle cx="12" cy="13" r="1.2" fill="currentColor" stroke="none"/>
      <circle cx="28" cy="12" r="0.9" fill="currentColor" stroke="none"/>
      <circle cx="29" cy="27" r="1.1" fill="currentColor" stroke="none"/>
      <circle cx="13" cy="28" r="0.8" fill="currentColor" stroke="none"/>
      <circle cx="31" cy="19" r="0.7" fill="currentColor" stroke="none"/>
    </svg>`,
  },
];
---

<Layout
  lang="en"
  title="Level 2: An Evolution of Sensitivity — Dan Healing Arts"
  description="The advanced training in fascia-based somatic bodywork. Deepen your capacity to feel subtle tissue intelligence, emotional currents, and the elemental language of the body."
  canonicalPath="/level-2"
>
  <Nav lang="en" />

  <main>

    <!-- ===== 1. HERO / INTRO ===== -->
    <FadeIn>
    <section class="pt-32 pb-24 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto">
        <TextImageSection image="/images/level2/hero.jpg" imageAlt="Advanced Level 2 bodywork training — practitioners deepening their sensitivity">
          <p class="font-sans text-xs font-bold uppercase tracking-[0.15rem] text-forest mb-4">Level 2 Training</p>
          <h1 class="font-serif text-4xl md:text-5xl text-text-main mb-6 leading-tight">
            An Evolution of Sensitivity
          </h1>
          <p class="font-sans text-stone text-lg italic mb-10 leading-relaxed">
            The natural next step for all who have completed the foundation.
          </p>
          <div class="font-sans text-stone leading-relaxed space-y-4">
            <p>
              Our Level 2 training is the natural next step for all who have completed the foundation. Here we deepen our capacity to feel the tissue's subtle intelligence, the quiet pulses of emotion, and the energetic currents that weave through the body.
            </p>
            <p>
              In addition to learning new massage sequences and release techniques, you'll discover how to enhance your sessions through trance induction, and intonation — tools that allow the body to surrender beyond the thinking mind.
            </p>
            <p>
              We also explore how posture, movement, and breath reflect the inner landscape of a person — and how these patterns can either restrict or support emotional flow.
            </p>
            <p>
              You'll learn to recognize these expressions in your clients and to meet them skillfully, integrating physical, emotional, and energetic dimensions into one coherent language of touch.
            </p>
            <p>
              This is where bodywork becomes art — when presence, sound, and movement begin to communicate more than technique ever could.
            </p>
          </div>
        </TextImageSection>
      </div>
    </section>
    </FadeIn>

    <!-- ===== TESTIMONIAL 1 ===== -->
    {jeremyUSA && (
      <TestimonialDivider
        quote={jeremyUSA.quote}
        name={jeremyUSA.name}
        location={jeremyUSA.location}
        photo={jeremyUSA.photo}
      />
    )}

    <!-- ===== PARALLAX — between sections ===== -->
    <Parallax src="/images/level2/massage-15.jpg" height="45vh" />

    <!-- ===== 2. THE LANGUAGE OF ELEMENTS ===== -->
    <FadeIn>
    <section class="py-12 md:py-16 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto max-w-3xl">
        <h2 class="font-serif text-3xl md:text-4xl text-text-main mb-8">
          The Language of the Elements and Emotions
        </h2>
        <div class="font-sans text-stone leading-relaxed space-y-4 mb-10">
          <p>
            This training unfolds as an inner journey through the five elements and the five primal emotions.
            Each element is an invitation to explore how emotion moves through your own body — not as a concept to apply, but as a direct experience.
          </p>
          <p>
            When you allow yourself to feel these qualities — the contraction of fear, the softening of sadness, the ignition of anger, the expansion of joy, the subtle withdrawal of shame — you begin to recognize them in the bodies of others with natural empathy and precision.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4 mb-10">
          {elements.map(({ element, emotion, icon }) => (
            <div class="bg-canvas rounded-card p-6 flex items-start gap-4">
              <div class="text-forest shrink-0 mt-0.5" set:html={icon} />
              <div>
                <p class="font-serif text-forest text-lg font-bold mb-1">{element}</p>
                <p class="font-sans text-stone text-sm">{emotion}</p>
              </div>
            </div>
          ))}
        </div>

        <h3 class="font-serif text-2xl text-text-main mb-4">Touching Emotion Through Presence</h3>
        <div class="font-sans text-stone leading-relaxed space-y-4">
          <p>
            In the practical bodywork sessions, we do not try to "work on fear" or "release sadness." Instead, we attune to what is alive in the field, and allow these elemental languages to inform the quality of our touch.
          </p>
          <p>
            Rather than aiming for catharsis, we explore presence as the medicine. Rather than trying to make something happen, we learn to listen so closely that the body begins to reorganize itself.
          </p>
          <p>
            Every emotion has its own rhythm, its own language, and our task as practitioners is simply to accompany that movement. To hold space without demand, and to allow the body's intelligence to unfold in its own time.
          </p>
        </div>
      </div>
    </section>
    </FadeIn>

    <!-- ===== TESTIMONIAL 2 ===== -->
    {robinUSA && (
      <TestimonialDivider
        quote={robinUSA.quote}
        name={robinUSA.name}
        location={robinUSA.location}
        photo={robinUSA.photo}
      />
    )}

    <!-- ===== PARALLAX — between sections ===== -->
    <Parallax src="/images/level2/dsc08054.jpg" height="45vh" />

    <!-- ===== 3. EMBODIMENT IN PRACTICE ===== -->
    <FadeIn>
    <section class="py-12 md:py-16 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto max-w-3xl">
        <TextImageSection image="/images/level2/massage-35.png" imageAlt="Practitioners working with emotional body dimensions in advanced bodywork training" reversed>
          <h2 class="font-serif text-3xl md:text-4xl text-text-main mb-8">
            Embodiment in Practice
          </h2>
          <div class="font-sans text-stone leading-relaxed space-y-4 mb-10">
            <p>
              Throughout the retreat, the five elements and their emotional resonances will color our movement, meditation, and partner work. They serve as mirrors, not methods — ways of refining perception and deepening your somatic vocabulary.
            </p>
            <p>
              We explore how the qualities of the elements express through touch, sound, and rhythm: the grounded steadiness of earth, the fluid yielding of water, the clear direction of fire, the expansive breath of air, and the spacious stillness of space.
            </p>
            <p>
              By journey's end, you will have learned not only new, advanced techniques, but a subtler form of listening — how to meet another person's body from the inside out, with presence that includes the whole spectrum of feeling.
            </p>
          </div>
        </TextImageSection>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-10">
          <div class="bg-surface-lo rounded-card p-8">
            <h3 class="font-serif text-xl text-text-main mb-3">Prerequisites</h3>
            <p class="font-sans text-stone leading-relaxed">
              Level 2 is open to all graduates of the Level 1 training. You bring your foundation — we deepen it together.
            </p>
          </div>
          <div class="bg-surface-lo rounded-card p-8">
            <h3 class="font-serif text-xl text-text-main mb-3">Format</h3>
            <p class="font-sans text-stone leading-relaxed">
              A 6-day immersive retreat combining hands-on bodywork, movement, meditation, and shared ceremony.
            </p>
          </div>
        </div>
      </div>
    </section>
    </FadeIn>

    <!-- ===== TESTIMONIAL 3 ===== -->
    {samUSA && (
      <TestimonialDivider
        quote={samUSA.quote}
        name={samUSA.name}
        location={samUSA.location}
        photo={samUSA.photo}
      />
    )}

    <!-- ===== 4. UPCOMING TRAININGS ===== -->
    <FadeIn>
    <section class="py-12 md:py-16 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto">
        <h2 class="font-serif text-3xl md:text-4xl text-text-main mb-10">
          Upcoming Level 2 Trainings
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-10">
          <TrainingCard
            title="An Evolution of Sensitivity"
            date="10–16 May 2026"
            location="Alpujarra, Spain"
            level="Level 2"
            href="/spain"
          />
        </div>
        <ApplyButton />
      </div>
    </section>
    </FadeIn>

  </main>

  <Footer lang="en" />

</Layout>
