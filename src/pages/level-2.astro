---
import { getCollection, getEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import TestimonialDivider from '../components/TestimonialDivider.astro';
import TrainingCard from '../components/TrainingCard.astro';
import ApplyButton from '../components/ApplyButton.astro';
import Parallax from '../components/Parallax.astro';
import TextImageSection from '../components/TextImageSection.astro';
import FadeIn from '../components/FadeIn.astro';
import StatsDivider from '../components/StatsDivider.astro';

const allTestimonials = await getCollection('testimonials');
const jeremyUSA = allTestimonials.find(t => t.id === 'jeremy-usa')?.data;
const robinUSA = allTestimonials.find(t => t.id === 'robin-usa')?.data;
const samUSA = allTestimonials.find(t => t.id === 'sam-usa')?.data;

const pageData = (await getEntry('retreats', 'level-2'))?.data;

// SVG icons stay hardcoded — they are presentation, not content
const elementIcons: Record<string, string> = {
  Earth: `<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
    <path d="M20 36 L5 11 L35 11 Z"/>
    <line x1="11" y1="22" x2="29" y2="22"/>
  </svg>`,
  Water: `<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
    <path d="M20 5 C11 15 11 22 11 27 A9 9 0 0 0 29 27 C29 22 29 15 20 5 Z"/>
    <path d="M14.5 23 C13.5 26 14 29 16.5 30.5"/>
  </svg>`,
  Fire: `<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
    <path d="M20 4 L5 29 L35 29 Z"/>
    <path d="M20 25 C23 20 23 16 20 12 C17 16 17 20 20 25"/>
  </svg>`,
  Air: `<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
    <path d="M8 13 Q20 8 32 13"/>
    <path d="M8 20 Q20 15 32 20"/>
    <path d="M8 27 Q20 22 32 27"/>
  </svg>`,
  Space: `<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="20" cy="20" r="15"/>
    <circle cx="20" cy="20" r="7"/>
    <circle cx="20" cy="20" r="1.5" fill="currentColor" stroke="none"/>
  </svg>`,
};

const elements = (pageData?.elements ?? []).map(({ element, emotion }) => ({
  element,
  emotion,
  icon: elementIcons[element] ?? '',
}));
---

<Layout
  lang="en"
  title={pageData?.page_title ?? "Level 2: An Evolution of Sensitivity — Dan Healing Arts"}
  description={pageData?.page_description ?? "The advanced training in fascia-based somatic bodywork. Deepen your capacity to feel subtle tissue intelligence, emotional currents, and the elemental language of the body."}
  canonicalPath="/level-2"
>
  <Nav lang="en" />

  <main>

    <!-- ===== 1. HERO / INTRO ===== -->
    <FadeIn>
    <section class="pt-32 pb-24 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto">
        <TextImageSection image={pageData?.hero.image ?? "/images/level2/hero.jpg"} imageAlt={pageData?.hero.imageAlt ?? "Advanced Level 2 bodywork training — practitioners deepening their sensitivity"} imagePosition={pageData?.hero.imagePosition ?? 'center'}>
          <p class="font-sans text-xs font-bold uppercase tracking-[0.15rem] text-forest mb-4">{pageData?.hero.badge ?? "Level 2 Training"}</p>
          <h1 class="font-serif text-4xl md:text-5xl text-text-main mb-6 leading-tight">
            {pageData?.hero.heading ?? "An Evolution of Sensitivity"}
          </h1>
          <p class="font-sans text-stone text-lg italic mb-10 leading-relaxed">
            {pageData?.hero.subheading ?? "The natural next step for all who have completed the foundation."}
          </p>
          <div class="font-sans text-stone leading-relaxed space-y-4">
            {(pageData?.hero.paragraphs ?? []).map((p) => <p>{p}</p>)}
          </div>
        </TextImageSection>
      </div>
    </section>
    </FadeIn>

    <!-- ===== TESTIMONIAL 1 ===== -->
    {jeremyUSA && (
      <TestimonialDivider
        quote={jeremyUSA.quote}
        name={jeremyUSA.name}
        location={jeremyUSA.location}
        photo={jeremyUSA.photo}
      />
    )}

    <!-- ===== PARALLAX — between sections ===== -->
    <Parallax src="/images/level2/massage-15.jpg" height="45vh" />

    <!-- ===== 2. THE LANGUAGE OF ELEMENTS ===== -->
    <FadeIn>
    <section class="py-12 md:py-16 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto max-w-3xl">
        <h2 class="font-serif text-3xl md:text-4xl text-text-main mb-8">
          The Language of the Elements and Emotions
        </h2>
        <div class="font-sans text-stone leading-relaxed space-y-4 mb-10">
          {pageData?.sections?.filter(s => s.id === 'elements_intro').flatMap(s => s.paragraphs).map((p) => (
            <p>{p}</p>
          ))}
        </div>

        <div class="grid grid-cols-5 gap-3 mb-10">
          {elements.map(({ element, emotion, icon }) => (
            <div class="bg-canvas rounded-card p-4 flex flex-col items-center text-center gap-3">
              <div class="text-forest" set:html={icon} />
              <div>
                <p class="font-serif text-forest text-lg font-bold mb-1">{element}</p>
                <p class="font-sans text-stone text-sm">{emotion}</p>
              </div>
            </div>
          ))}
        </div>

        <h3 class="font-serif text-2xl text-text-main mb-4">Touching Emotion Through Presence</h3>
        <div class="font-sans text-stone leading-relaxed space-y-4">
          {pageData?.sections?.filter(s => s.id === 'touching_emotion').flatMap(s => s.paragraphs).map((p) => (
            <p>{p}</p>
          ))}
        </div>
      </div>
    </section>
    </FadeIn>

    <!-- ===== TESTIMONIAL 2 ===== -->
    {robinUSA && (
      <TestimonialDivider
        quote={robinUSA.quote}
        name={robinUSA.name}
        location={robinUSA.location}
        photo={robinUSA.photo}
      />
    )}

    <!-- ===== PARALLAX — between sections ===== -->
    <Parallax src="/images/level2/dsc08054.jpg" height="45vh" />

    <!-- ===== 3. EMBODIMENT IN PRACTICE ===== -->
    <FadeIn>
    <section class="py-12 md:py-16 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto max-w-3xl">
        <TextImageSection image="/images/level2/massage-35.png" imageAlt="Practitioners working with emotional body dimensions in advanced bodywork training" reversed>
          <h2 class="font-serif text-3xl md:text-4xl text-text-main mb-8">
            Embodiment in Practice
          </h2>
          <div class="font-sans text-stone leading-relaxed space-y-4 mb-10">
            {pageData?.sections?.filter(s => s.id === 'embodiment').flatMap(s => s.paragraphs).map((p) => (
              <p>{p}</p>
            ))}
          </div>
        </TextImageSection>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-10">
          <div class="bg-surface-lo rounded-card p-8">
            <h3 class="font-serif text-xl text-text-main mb-3">Prerequisites</h3>
            <p class="font-sans text-stone leading-relaxed">
              Level 2 is open to all graduates of the Level 1 training. You bring your foundation — we deepen it together.
            </p>
          </div>
          <div class="bg-surface-lo rounded-card p-8">
            <h3 class="font-serif text-xl text-text-main mb-3">Format</h3>
            <p class="font-sans text-stone leading-relaxed">
              A 6-day immersive retreat combining hands-on bodywork, movement, meditation, and shared ceremony.
            </p>
          </div>
        </div>
      </div>
    </section>
    </FadeIn>

    <!-- ===== TESTIMONIAL 3 ===== -->
    {samUSA && (
      <TestimonialDivider
        quote={samUSA.quote}
        name={samUSA.name}
        location={samUSA.location}
        photo={samUSA.photo}
      />
    )}

    <!-- ===== 4. UPCOMING TRAININGS ===== -->
    <FadeIn>
    <section class="py-12 md:py-16 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto">
        <h2 class="font-serif text-3xl md:text-4xl text-text-main mb-10">
          Upcoming Level 2 Trainings
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-10">
          <TrainingCard
            title="An Evolution of Sensitivity"
            date="10–16 May 2026"
            location="Alpujarra, Spain"
            level="Level 2"
            href="/spain"
            image="/images/spain/hero.jpg"
          />
        </div>
        <ApplyButton />
      </div>
    </section>
    </FadeIn>

  </main>

  <Footer lang="en" />

</Layout>
