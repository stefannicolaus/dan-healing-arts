---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import TestimonialDivider from '../components/TestimonialDivider.astro';
import TextImageSection from '../components/TextImageSection.astro';
import Parallax from '../components/Parallax.astro';
import ApplyButton from '../components/ApplyButton.astro';

const allTestimonials = await getCollection('testimonials');
const rebeccaCanada = allTestimonials.find(t => t.id === 'rebecca-canada')?.data;
const lasseFinland = allTestimonials.find(t => t.id === 'lasse-finland')?.data;
---

<Layout
  lang="en"
  title="Somatic Deep Tissue Bodywork — Private Sessions with Daniel Wendt"
  description="Deep, slow bodywork with Daniel Wendt. Myofascial work that reaches beyond muscles and fascia — touching the nervous system and emotional body. Zürich & worldwide."
  canonicalPath="/sessions"
>
  <Nav lang="en" />

  <main>

    <!-- ===== 1. HERO ===== -->
    <section class="relative">
      <div class="relative w-full h-[70vh] min-h-[500px] overflow-hidden">
        <img
          src="/images/general/dan-outside-38.jpg"
          alt="Somatic Deep Tissue Bodywork with Daniel Wendt"
          class="absolute inset-0 w-full h-full object-cover"
        />
        <div class="absolute inset-0 bg-gradient-to-b from-black/50 via-black/30 to-black/60"></div>
        <div class="absolute inset-0 flex flex-col items-center justify-center text-center px-6">
          <h1 class="font-serif text-white text-4xl md:text-6xl lg:text-7xl mb-4">
            Somatic Deep Tissue Bodywork
          </h1>
          <p class="font-sans text-white/90 text-lg md:text-xl mb-8">
            Private Sessions with Daniel Wendt
          </p>
          <p class="font-sans text-white/80 text-base md:text-lg max-w-2xl italic mb-10">
            A deep, slow bodywork practice that reaches beyond muscles and fascia — touching the nervous system and emotional body. Each session is an individual process, held in presence, awareness, and trust.
          </p>
          <ApplyButton text="Book a Session" href="/contact" />
        </div>
      </div>
    </section>

    <!-- ===== 2. WHAT IS SOMATIC DEEP TISSUE BODYWORK? ===== -->
    <section class="py-24 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto">
        <TextImageSection
          image="/images/about/massage-25.jpg"
          imageAlt="Daniel Wendt offering somatic bodywork"
        >
          <h2 class="font-serif text-3xl md:text-4xl text-text-main mb-6">
            What is Somatic Deep Tissue Bodywork?
          </h2>
          <div class="font-sans text-stone leading-relaxed space-y-4">
            <p>
              Somatic deep tissue bodywork combines precise fascial work with deep attention to what is stored in the body. Slow, mindful touch doesn't just release physical tension — it creates space for what lies beneath.
            </p>
            <p>
              Daniel works with the myofascial structures of the body: the layers of connective tissue that surround and connect muscles, organs, and joints. Through targeted, deep pressure and somatic presence, tensions that have been held in the body for years can begin to release.
            </p>
            <p>
              The work is never purely mechanical. It always considers the emotional and energetic qualities stored in different areas of the body.
            </p>
          </div>
        </TextImageSection>
      </div>
    </section>

    <!-- ===== 3. TESTIMONIAL — REBECCA, CANADA ===== -->
    {rebeccaCanada && (
      <TestimonialDivider
        quote={rebeccaCanada.quote}
        name={rebeccaCanada.name}
        location={rebeccaCanada.location}
        photo={rebeccaCanada.photo}
      />
    )}

    <!-- ===== 4. PARALLAX ===== -->
    <Parallax src="/images/level1/inside-12.jpg" height="45vh" />

    <!-- ===== 5. WHO IS THIS WORK FOR? ===== -->
    <section class="py-24 px-6 md:px-12 bg-surface-lo">
      <div class="max-w-page mx-auto">
        <h2 class="font-serif text-3xl md:text-4xl text-text-main mb-10 text-center">
          Who Is This Work For?
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
          <div class="bg-canvas rounded-card p-8">
            <h3 class="font-serif text-xl text-text-main mb-3">Chronic Tension</h3>
            <p class="font-sans text-stone leading-relaxed">
              Neck, back, shoulders — deep release of tension patterns built up over years.
            </p>
          </div>
          <div class="bg-canvas rounded-card p-8">
            <h3 class="font-serif text-xl text-text-main mb-3">Emotional Processing</h3>
            <p class="font-sans text-stone leading-relaxed">
              The body stores what the mind suppresses. Somatic bodywork can help gently open these layers.
            </p>
          </div>
          <div class="bg-canvas rounded-card p-8">
            <h3 class="font-serif text-xl text-text-main mb-3">Exhaustion & Burnout</h3>
            <p class="font-sans text-stone leading-relaxed">
              An invitation to let the nervous system settle. Arriving in your own body, finding space to breathe.
            </p>
          </div>
          <div class="bg-canvas rounded-card p-8">
            <h3 class="font-serif text-xl text-text-main mb-3">Body Awareness</h3>
            <p class="font-sans text-stone leading-relaxed">
              For anyone seeking a deeper connection to their own body — whether as a personal practice or alongside yoga, meditation, or therapy.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== 6. HOW A SESSION WORKS ===== -->
    <section class="py-24 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto">
        <TextImageSection
          image="/images/general/dan-two-men.jpg"
          imageAlt="Daniel Wendt during a private bodywork session"
          reversed
        >
          <h2 class="font-serif text-3xl md:text-4xl text-text-main mb-6">
            How a Session Works
          </h2>
          <div class="font-sans text-stone leading-relaxed space-y-4">
            <p>
              Each session begins with a brief conversation — what brings you here, what you need, what's present. Then we work together on the body.
            </p>
            <p>
              The touch is slow, deep, and mindful. I follow the structures of the body — the fascia, the muscles, the rhythm of your nervous system. Some areas need intensity, others softness. The body shows what it needs.
            </p>
            <p>
              After the session, there is time to arrive and settle. Many people report deep relaxation, new clarity, or a feeling of lightness.
            </p>
          </div>
        </TextImageSection>
      </div>
    </section>

    <!-- ===== 7. TESTIMONIAL — LASSE, FINLAND ===== -->
    {lasseFinland && (
      <TestimonialDivider
        quote={lasseFinland.quote}
        name={lasseFinland.name}
        location={lasseFinland.location}
        photo={lasseFinland.photo}
      />
    )}

    <!-- ===== 8. PARALLAX ===== -->
    <Parallax src="/images/level1/outside-27.jpg" height="45vh" />

    <!-- ===== 9. PRICING & BOOKING ===== -->
    <section class="py-24 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto">
        <h2 class="font-serif text-3xl md:text-4xl text-text-main mb-4">
          Pricing & Booking
        </h2>
        <p class="font-sans text-stone text-base italic mb-10">
          Jupiterhaus im Frankental, Zürich
        </p>

        <div class="flex flex-col sm:flex-row gap-6 mb-10">
          <div class="bg-surface-lo rounded-card px-10 py-8 flex flex-col items-center text-center">
            <p class="font-serif text-text-main text-2xl mb-1">90 minutes</p>
            <p class="font-sans text-forest text-3xl font-bold mt-2">180 CHF</p>
          </div>
          <div class="bg-surface-lo rounded-card px-10 py-8 flex flex-col items-center text-center">
            <p class="font-serif text-text-main text-2xl mb-1">120 minutes</p>
            <p class="font-sans text-forest text-3xl font-bold mt-2">230 CHF</p>
          </div>
        </div>

        <p class="font-sans text-stone leading-relaxed max-w-2xl mb-10">
          Daniel also offers sessions at other locations when traveling. For current availability and appointments, please get in touch directly.
        </p>

        <ApplyButton text="Book a Session" href="/contact" />
      </div>
    </section>

    <!-- ===== 10. CLOSING STATEMENT ===== -->
    <section class="py-20 px-6 md:px-12 bg-surface-lo">
      <div class="max-w-page mx-auto text-center max-w-3xl">
        <p class="font-serif italic text-text-main text-xl md:text-2xl leading-relaxed">
          Every touch is an invitation. Not to fix something — but to listen to what the body has to say.
        </p>
      </div>
    </section>

  </main>

  <Footer lang="en" />

</Layout>
