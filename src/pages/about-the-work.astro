---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import TestimonialDivider from '../components/TestimonialDivider.astro';
import ApplyButton from '../components/ApplyButton.astro';
import Parallax from '../components/Parallax.astro';
import TextImageSection from '../components/TextImageSection.astro';
import FadeIn from '../components/FadeIn.astro';
import StatsDivider from '../components/StatsDivider.astro';
import { getPage, getTestimonials } from '../lib/queries';
import { imageUrl } from '../lib/sanity';

const allTestimonials = await getTestimonials();
const ilinca = allTestimonials.find((t: any) => t.name === 'Ilinca');
const nico = allTestimonials.find((t: any) => t.name === 'Nico');
const viri = allTestimonials.find((t: any) => t.name === 'Viri');
const pageData = await getPage('about-the-work');
---

<Layout
  lang="en"
  title={pageData?.page_title ?? "About the Work — Dan Healing Arts"}
  description={pageData?.page_description ?? "Myofascial Somatic Liberation — a holistic approach to deep, slow bodywork where presence and sensitivity open space for profound emotional release and transformation."}
  canonicalPath="/about-the-work"
>
  <Nav lang="en" />

  <main>

    <!-- ===== 1. HERO ===== -->
    <FadeIn>
    <section class="pt-32 pb-24 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto">
        <TextImageSection image={imageUrl(pageData?.hero_image, "/images/about/work-hero.jpg")} imageAlt="Daniel Wendt practicing myofascial somatic bodywork">
          <h1 class="font-serif text-4xl md:text-5xl text-text-main mb-6 leading-tight">
            {pageData?.hero_heading ?? "Myofascial Somatic Liberation"}
          </h1>
          <p class="font-sans text-stone text-lg italic mb-10 leading-relaxed">
            {pageData?.hero_subheading ?? "A holistic approach to deep, slow and nuanced bodywork."}
          </p>
          <div class="font-sans text-stone leading-relaxed space-y-4">
            {(pageData?.hero_paragraphs ?? [
              "Myofascial Somatic Liberation is a holistic approach to deep, slow and nuanced bodywork — where presence, sensitivity and depth open space for profound emotional release and inner transformation.",
              "At its core, this work is a unique and well-balanced blend of myofascial release, deep tissue massage, and energy work. It brings playful ease into therapeutic depth, grounding mystical insight in the physical tissue through a bridge of modern anatomy.",
              "It is a method designed to relieve chronic tension, pain, and deeply held emotional patterns — all while honoring the natural rhythm of your nervous system and supporting your body's primal needs.",
              "This naturally leads us to two essential elements for applying deep touch: slowness and simplicity.",
            ]).map((p) => <p>{p}</p>)}
          </div>
        </TextImageSection>
      </div>
    </section>
    </FadeIn>

    <!-- ===== TESTIMONIAL: ILINCA ===== -->
    {ilinca && (
      <TestimonialDivider
        quote={ilinca.quote}
        name={ilinca.name}
        location={ilinca.location}
        photo={ilinca.photo}
      />
    )}

    <!-- ===== 2. THE POWER OF SLOWNESS ===== -->
    <FadeIn>
    <section class="py-12 md:py-16 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto">
        {(() => { const s = pageData?.sections?.find((s: any) => s.id === 'slowness'); return (
        <TextImageSection image={imageUrl(s?.image, "/images/about/daniel-7165.jpg")} imageAlt={s?.imageAlt ?? "Deep slow bodywork session demonstrating the power of presence and slowness"} reversed>
          <h2 class="font-serif text-3xl md:text-4xl text-text-main mb-8">
            {s?.heading ?? "The Power of Slowness"}
          </h2>
          <div class="font-sans text-stone leading-relaxed space-y-4">
            {(s?.paragraphs ?? [
              "Slowness is the most powerful tool for guiding the body out of protective patterns and into a parasympathetic state, where rest, regulation, and a deep sense of safety emerge. It invites trust, not only between giver and receiver, but also within the body itself. From that trust, the release of held emotion and stagnant energy unfolds naturally.",
              "At the same time, the body's connective tissue — the fascia — requires time to feel, respond, and reorganize. It opens when it's met with presence. Through slowing down, we give the system space to adapt and unwind. Muscular tension and subtle patterns of resistance begin to soften — not because we push through them, but because we listen.",
              "By allowing the body to set the pace, we are guided into deeper layers that would otherwise remain hidden, creating the conditions for real transformation to occur.",
            ]).map((p) => <p>{p}</p>)}
          </div>
        </TextImageSection>
        ); })()}
      </div>
    </section>
    </FadeIn>

    <!-- ===== TESTIMONIAL: NICO ===== -->
    {nico && (
      <TestimonialDivider
        quote={nico.quote}
        name={nico.name}
        location={nico.location}
        photo={nico.photo}
      />
    )}

    <!-- ===== PARALLAX — between major sections ===== -->
    <Parallax src="/images/about/learning-banner.jpg" height="45vh" />

    <!-- ===== 3. THE EASE OF SIMPLICITY ===== -->
    <FadeIn>
    <section class="py-12 md:py-16 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto">
        {(() => { const s = pageData?.sections?.find((s: any) => s.id === 'simplicity'); return (
        <TextImageSection image={imageUrl(s?.image, "/images/about/massage-25.jpg")} imageAlt={s?.imageAlt ?? "Close-up of hands working on the neck demonstrating the ease and simplicity of deep bodywork"}>
          <h2 class="font-serif text-3xl md:text-4xl text-text-main mb-8">
            {s?.heading ?? "The Ease of Simplicity"}
          </h2>
          <div class="font-sans text-stone leading-relaxed space-y-4">
            {(s?.paragraphs ?? [
              "True depth comes not from complexity, but from simplicity and attunement. We don't need to create complicated techniques and sequences or get lost in an over-intellectualized approach to anatomy. Instead, we learn to follow the body's natural structures — muscle pathways, fascial lines, bones, joints, ligaments, and energy channels — which clearly reveal themselves when we slow down, listen, and feel.",
              "This work is never mechanical. It requires moment-to-moment listening, a dance between your hands, your presence, and the subtle intelligence within the body. It's about sensing the unique physical and energetic landscape beneath your hands, and how touching someone also affects you.",
            ]).map((p) => <p>{p}</p>)}
          </div>
        </TextImageSection>
        ); })()}
      </div>
    </section>
    </FadeIn>

    <!-- ===== 4. SELF-CARE FOR THE PRACTITIONER ===== -->
    <FadeIn>
    <section class="py-12 md:py-16 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto">
        <TextImageSection image="/images/about/work-3.jpg" imageAlt="Daniel Wendt working with a student outdoors — self-care and sustainable practice" reversed>
          <h2 class="font-serif text-3xl md:text-4xl text-text-main mb-8">
            Self-care for the Practitioner
          </h2>
          <div class="font-sans text-stone leading-relaxed space-y-4">
            <p>
              The givers' well-being is often overlooked — yet it is the foundation of all true support. Our own physical and emotional state shapes not only the quality of our touch, but the depth to which we can hold space for another. That's why this work emphasizes self-awareness, proper use of body weight, alignment, and nervous system regulation — not only for your clients, but for you.
            </p>
            <p>
              To truly offer support, we must begin with ourselves. Honoring our limits. Listening to our needs. Creating space to rest and refill. From this place of inner balance, our presence becomes clear, our hands attuned, and the work becomes sustainable — filled with ease, inspiration, and joy that radiates far beyond the treatment room.
            </p>
          </div>
        </TextImageSection>
      </div>
    </section>
    </FadeIn>

    <!-- ===== TESTIMONIAL: VIRI ===== -->
    {viri && (
      <TestimonialDivider
        quote={viri.quote}
        name={viri.name}
        location={viri.location}
        photo={viri.photo}
      />
    )}

    <!-- ===== 5. LEARNING IN A SHARED FIELD ===== -->
    <FadeIn>
    <section class="py-12 md:py-16 px-6 md:px-12 bg-canvas">
      <div class="max-w-page mx-auto">
        <TextImageSection image="/images/about/work-4.jpg" imageAlt="Group of participants learning together in a shared training field">
          <h2 class="font-serif text-3xl md:text-4xl text-text-main mb-8">
            Learning in a Shared Field
          </h2>
          <div class="font-sans text-stone leading-relaxed space-y-4 mb-10">
            <p>
              This work is way more than technique. It is a path of transformation for both individuals and communities. Integrated with somatic practices, yoga, meditation, breathwork and ceremony, it unfolds in a safe, nurturing space at beautiful locations around the world. Here, learning happens through living: observing, practicing, receiving, and releasing together.
            </p>
            <p>
              In this warm-hearted and playful atmosphere, surrounded by a nourishing group energy of mutual acceptance, connection and trust, these retreats are powerful journeys — opportunities to release, expand, and empower one another, with more presence and purpose to carry into the world.
            </p>
          </div>
          <ApplyButton />
        </TextImageSection>
      </div>
    </section>
    </FadeIn>

  </main>

  <Footer lang="en" />

</Layout>
