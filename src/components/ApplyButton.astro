---
interface Props {
  text?: string;
  href?: string;
}

const { text = 'Apply for the Training', href = '/contact' } = Astro.props;
---

<a
  href={href}
  class="inline-flex items-center px-8 py-3.5 bg-forest text-white rounded-btn font-medium text-base hover:bg-sage transition-colors duration-200"
>
  {text}
</a>
