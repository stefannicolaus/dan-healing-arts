---
interface Props {
  label?: string;
  heading?: string;
  paragraphs?: string[];
  highlight?: string;
  image?: string;
  imageAlt?: string;
}
const { label, heading, paragraphs = [], highlight, image, imageAlt } = Astro.props;
const imageSrc = image ?? '/images/general/dan-outside-38.jpg';
---

<section class="py-12 md:py-16 px-6 md:px-12 bg-canvas">
  <div class="max-w-page mx-auto">
    <div class="flex flex-col md:flex-row gap-12 lg:gap-20 items-center">
      <div class="w-full md:w-[45%] shrink-0">
        <div class="rounded-card overflow-hidden aspect-[4/3]">
          <img
            src={imageSrc}
            alt={imageAlt ?? ''}
            class="w-full h-full object-cover object-center"
          />
        </div>
      </div>
      <div class="w-full md:w-[55%]">
        <span class="font-sans font-bold tracking-[0.2em] uppercase text-xs text-sage mb-5 block">
          {label}
        </span>
        <h2 class="font-serif font-black text-forest text-3xl md:text-4xl mb-8 tracking-tight">
          {heading}
        </h2>
        <div class="space-y-4 font-sans text-stone text-base md:text-lg leading-[1.75]">
          {paragraphs.map((p) => <p>{p}</p>)}
          {highlight && (
            <p class="font-medium text-forest">{highlight}</p>
          )}
        </div>
      </div>
    </div>
  </div>
</section>
