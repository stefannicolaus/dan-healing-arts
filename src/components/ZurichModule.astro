---
import { getCollection } from 'astro:content';
const moduleData = await getCollection('courses');
// Sort by nr field (Modul 1, 2, 3, 4)
const module = moduleData
  .sort((a, b) => a.data.nr.localeCompare(b.data.nr))
  .map(m => m.data);


---

<section id="module" class="bg-parchment">

  <!-- Header -->
  <div class="py-12 md:py-16 max-w-page mx-auto px-6 md:px-12">
    <h2 class="font-serif font-black text-forest text-4xl md:text-6xl mb-4 tracking-tight">
      Die vier Module
    </h2>
    <p class="font-sans text-stone text-xl">
      Alle Module können unabhängig voneinander besucht werden — und entfalten im Zusammenspiel ihre volle Tiefe.
    </p>
  </div>

  <!-- Module: gestapelt, abwechselnd links/rechts -->
  {module.map((m, i) => (
    <>
      <!-- Trenner vor jedem Modul -->
      <div class="py-2 px-6 flex items-center justify-center gap-6 max-w-page mx-auto">
        <div class="flex-1 h-px bg-stone/30"></div>
        <img src="/images/dan-logo-v2.png" alt="" aria-hidden="true" class="h-8 w-auto opacity-40" />
        <div class="flex-1 h-px bg-stone/30"></div>
      </div>

      <div class="py-12 md:py-16 max-w-page mx-auto px-6 md:px-12">
        <div class={`flex flex-col ${m.bildLinks ? 'md:flex-row' : 'md:flex-row-reverse'} gap-12 lg:gap-20 items-center`}>

          <!-- Bild -->
          <div class="w-full md:w-[45%] shrink-0">
            <div class="rounded-card overflow-hidden aspect-[4/3]">
              <img
                src={m.bild}
                alt={m.bildAlt}
                class={`w-full h-full object-cover ${m.bildPos}`}
              />
            </div>
          </div>

          <!-- Text -->
          <div class="w-full md:w-[55%]">
            <span class="font-sans font-bold text-xs tracking-widest uppercase text-sage mb-2 block">
              {m.nr}
            </span>
            <p class="font-sans text-stone/60 text-sm italic mb-4">{m.motto}</p>
            <h3 class="font-serif font-black text-forest text-3xl md:text-4xl mb-6 tracking-tight">
              {m.titel}
            </h3>
            <p class="font-sans text-stone text-base md:text-lg leading-[1.75] mb-6">
              {m.beschreibung}
            </p>
            <ul class="space-y-2 mb-8">
              {m.schwerpunkte.map((punkt) => (
                <li class="font-sans text-stone/80 text-sm flex items-start gap-2">
                  <span class="text-sage mt-0.5 shrink-0">—</span>
                  {punkt}
                </li>
              ))}
            </ul>
            <div class="flex flex-wrap gap-3 text-sm font-medium text-stone mb-6">
              <span class="px-3 py-1.5 bg-canvas rounded-full border border-stone/15">{m.datum}</span>
              <span class="px-3 py-1.5 bg-canvas rounded-full border border-stone/15">420 CHF</span>
              <span class="px-3 py-1.5 bg-canvas rounded-full border border-stone/15">Jupiterhaus Zürich</span>
            </div>
            <a
              href="/contact"
              class="inline-flex items-center px-7 py-3 bg-forest text-white rounded-btn font-medium hover:bg-sage transition-colors duration-200"
            >
              Anmelden →
            </a>
          </div>

        </div>
      </div>
    </>
  ))}

  <p class="pb-12 text-center font-sans text-stone text-sm italic">
    Alle Module einzeln buchbar oder als Gesamtreihe — jeweils 9:30–19:30 Uhr
  </p>

</section>
