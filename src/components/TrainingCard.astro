---
interface Props {
  title: string;
  date: string;
  location: string;
  level: string;
  href: string;
}

const { title, date, location, level, href } = Astro.props;
---

<a
  href={href}
  class="training-card block bg-white border-l-4 border-forest border border-stone/10 rounded-card p-8 hover:shadow-lg transition-all duration-200 group relative"
>
  <!-- Level badge -->
  <span class="inline-block font-sans text-xs font-bold uppercase tracking-[0.15rem] text-forest bg-forest/10 px-3 py-1 rounded-btn mb-4">
    {level}
  </span>

  <h3 class="font-serif font-black text-text-main text-xl leading-tight mb-4 group-hover:text-forest transition-colors pr-8">
    {title}
  </h3>

  <div class="space-y-1.5">
    <!-- Date row -->
    <p class="font-sans text-stone text-sm flex items-center gap-2">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-forest/60" aria-hidden="true">
        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
        <line x1="16" y1="2" x2="16" y2="6"/>
        <line x1="8" y1="2" x2="8" y2="6"/>
        <line x1="3" y1="10" x2="21" y2="10"/>
      </svg>
      {date}
    </p>
    <!-- Location row -->
    <p class="font-sans text-stone text-sm flex items-center gap-2">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-forest/60" aria-hidden="true">
        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
        <circle cx="12" cy="10" r="3"/>
      </svg>
      {location}
    </p>
  </div>

  <!-- Arrow icon, positioned bottom-right, slides right on hover -->
  <span class="absolute bottom-6 right-6 text-forest/40 group-hover:text-forest group-hover:translate-x-1 transition-all duration-200" aria-hidden="true">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="5" y1="12" x2="19" y2="12"/>
      <polyline points="12 5 19 12 12 19"/>
    </svg>
  </span>
</a>

<style>
  .training-card:hover {
    transform: translateY(-2px);
  }
</style>
