---
interface Props {
  lang?: string;
}

const { lang = 'en' } = Astro.props;

const isDe = lang === 'de';
const jahr = new Date().getFullYear();
---

<footer class="bg-surface-lo border-t border-stone/20 py-16 px-6 md:px-12">
  <div class="max-w-page mx-auto">

    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">

      <!-- Brand -->
      <div class="space-y-4">
        <p class="font-serif font-black text-forest text-lg">Dan Healing Arts</p>
        {isDe ? (
          <p class="font-sans text-stone text-sm leading-relaxed max-w-xs">
            Somatische Tiefenmassage & Faszien Release — Wochenendkurse in Zürich
          </p>
        ) : (
          <p class="font-sans text-stone text-sm leading-relaxed max-w-xs">
            Immersive trainings in fascia-based somatic bodywork. Learn to listen with your hands.
          </p>
        )}
        <p class="font-sans text-stone text-sm">
          <a href="mailto:danhealingarts@gmail.com" class="hover:text-forest transition-colors">
            danhealingarts@gmail.com
          </a>
        </p>
      </div>

      <!-- Navigation -->
      <div class="space-y-3">
        <p class="font-sans text-xs font-bold uppercase tracking-[0.18rem] text-forest mb-4">
          {isDe ? 'Navigation' : 'Navigation'}
        </p>
        {isDe ? (
          <>
            <a href="#methode" class="block font-sans text-stone text-sm hover:text-forest transition-colors">Die Methode</a>
            <a href="#module" class="block font-sans text-stone text-sm hover:text-forest transition-colors">Module</a>
            <a href="#ueber" class="block font-sans text-stone text-sm hover:text-forest transition-colors">Über Daniel</a>
            <a href="#kontakt" class="block font-sans text-stone text-sm hover:text-forest transition-colors">Anmeldung</a>
          </>
        ) : (
          <>
            <a href="/about" class="block font-sans text-stone text-sm hover:text-forest transition-colors">About this work</a>
            <a href="/level-1" class="block font-sans text-stone text-sm hover:text-forest transition-colors">Level 1</a>
            <a href="/level-2" class="block font-sans text-stone text-sm hover:text-forest transition-colors">Level 2</a>
            <a href="/about-dan" class="block font-sans text-stone text-sm hover:text-forest transition-colors">About Dan</a>
            <a href="/contact" class="block font-sans text-stone text-sm hover:text-forest transition-colors">Contact</a>
          </>
        )}
      </div>

      <!-- Connect -->
      <div class="space-y-3">
        <p class="font-sans text-xs font-bold uppercase tracking-[0.18rem] text-forest mb-4">
          {isDe ? 'Verbinden' : 'Connect'}
        </p>
        <a href="https://www.instagram.com/dan.healing.arts/" target="_blank" rel="noopener" class="inline-flex items-center gap-2 font-sans text-stone text-sm hover:text-forest transition-colors">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
          </svg>
          @dan.healing.arts
        </a>
        {isDe ? (
          <a href="/" class="block font-sans text-stone text-sm hover:text-forest transition-colors">
            English site →
          </a>
        ) : (
          <a href="/zurich" class="block font-sans text-stone text-sm hover:text-forest transition-colors">
            Kurse Zürich (Deutsch) →
          </a>
        )}
        <p class="font-sans text-stone/60 text-xs pt-2">
          {isDe ? (
            <>Verantwortlich: Daniel Wendt<br />danhealingarts@gmail.com</>
          ) : (
            <>Daniel Wendt<br />danhealingarts@gmail.com</>
          )}
        </p>
      </div>

    </div>

    <div class="border-t border-stone/20 pt-8">
      <p class="font-sans text-stone/60 text-xs text-center">
        {isDe
          ? `© ${jahr} Dan Healing Arts. Alle Module finden statt im Jupiterhaus Zürich.`
          : `© ${jahr} Dan Healing Arts. All rights reserved.`}
      </p>
    </div>

  </div>
</footer>
