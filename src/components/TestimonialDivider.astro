---
interface Props {
  quote: string;
  name: string;
  location: string;
  photo?: string;
}

const { quote, name, location, photo } = Astro.props;
---

<div class="testimonial-divider bg-surface-lo py-20 md:py-32 px-6 md:px-12">
  <div class="max-w-page mx-auto">

    {photo ? (
      <!-- With photo: left-aligned, photo beside attribution -->
      <div class="max-w-3xl mx-auto">
        <span class="block font-serif text-forest/20 leading-none select-none mb-4" style="font-size: clamp(5rem, 12vw, 9rem); line-height: 0.8;" aria-hidden="true">"</span>
        <p class="font-serif italic text-text-main text-xl md:text-2xl leading-relaxed mb-8">
          {quote}
        </p>
        <div class="flex items-center gap-4">
          <img
            src={photo}
            alt={name}
            class="w-14 h-14 rounded-full object-cover shrink-0"
          />
          <p class="font-sans text-stone text-sm font-medium">
            — {name} <span class="font-normal text-stone/70">{location}</span>
          </p>
        </div>
      </div>
    ) : (
      <!-- Without photo: centered -->
      <div class="text-center max-w-3xl mx-auto">
        <span class="block font-serif text-forest/20 leading-none select-none mb-4" style="font-size: clamp(5rem, 12vw, 9rem); line-height: 0.8;" aria-hidden="true">"</span>
        <p class="font-serif italic text-text-main text-xl md:text-2xl leading-relaxed mb-8">
          {quote}
        </p>
        <p class="font-sans text-stone text-sm font-medium">
          — {name} <span class="font-normal text-stone/70">{location}</span>
        </p>
      </div>
    )}

  </div>
</div>

<style>
  .testimonial-divider {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 600ms ease, transform 600ms ease;
  }

  .testimonial-divider.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const dividers = document.querySelectorAll('.testimonial-divider');

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.15 }
  );

  dividers.forEach((el) => observer.observe(el));
</script>
