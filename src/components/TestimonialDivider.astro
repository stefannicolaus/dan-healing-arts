---
interface Props {
  quote: string;
  name: string;
  location: string;
  photo?: string;
}

const { quote, name, location, photo } = Astro.props;
---

<div class="testimonial-divider py-10 md:py-14 px-6 md:px-12" style="background-color: #E8E0D4;">
  <div class="max-w-3xl mx-auto text-center">
    {photo ? (
      <div class="flex flex-col items-center">
        <p class="font-serif italic text-forest text-lg md:text-xl leading-relaxed">
          &ldquo;{quote}&rdquo;
        </p>
        <div class="flex items-center gap-3 mt-6">
          <img
            src={photo}
            alt={name}
            class="w-10 h-10 rounded-full object-cover shrink-0"
          />
          <p class="font-sans text-umber/70 text-sm">
            — {name}, {location}
          </p>
        </div>
      </div>
    ) : (
      <div>
        <p class="font-serif italic text-forest text-lg md:text-xl leading-relaxed">
          &ldquo;{quote}&rdquo;
        </p>
        <p class="font-sans text-umber/70 text-sm mt-6">
          — {name}, {location}
        </p>
      </div>
    )}
  </div>
</div>

<style>
  .testimonial-divider {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 500ms ease, transform 500ms ease;
  }

  .testimonial-divider.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const dividers = document.querySelectorAll('.testimonial-divider');

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.15 }
  );

  dividers.forEach((el) => observer.observe(el));
</script>
