---
interface Props {
  image?: string;
  imageAlt?: string;
  reversed?: boolean;
  imagePosition?: string;
}

const { image, imageAlt, reversed = false, imagePosition = 'center' } = Astro.props;
---

{image ? (
  <div class={`flex flex-col ${reversed ? 'md:flex-row-reverse' : 'md:flex-row'} gap-12 md:gap-16 items-center`}>
    <div class="w-full md:w-1/2 shrink-0">
      <img
        src={image}
        alt={imageAlt}
        class="w-full h-auto rounded-card object-cover"
        style={`object-position: ${imagePosition}`}
        loading="lazy"
      />
    </div>
    <div class="w-full md:w-1/2">
      <slot />
    </div>
  </div>
) : (
  <div class="max-w-3xl">
    <slot />
  </div>
)}
