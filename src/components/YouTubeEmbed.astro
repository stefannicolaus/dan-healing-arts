---
interface Props {
  videoId: string;
  title?: string;
}

const { videoId, title = 'Video' } = Astro.props;
---

<div class="w-full aspect-video rounded-card overflow-hidden">
  <iframe
    src={`https://www.youtube-nocookie.com/embed/${videoId}`}
    title={title}
    class="w-full h-full"
    frameborder="0"
    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
    allowfullscreen
    loading="lazy"
  ></iframe>
</div>
