<section class="relative">
  <div class="relative w-full h-[85vh] min-h-[600px] overflow-hidden">
    <img
      src="/images/about/work-hero.jpg"
      alt="Daniel Wendt bei der somatischen Körperarbeit — Hände auf Gewebe, ruhig und präzise"
      class="absolute inset-0 w-full h-full object-cover object-top"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/40 via-black/20 to-black/45"></div>
    <div class="absolute inset-0 flex flex-col items-center justify-center text-center px-6 pt-20">
      <h1 class="font-serif font-black text-white text-4xl md:text-5xl lg:text-7xl leading-[1.05] tracking-tight mb-6 max-w-4xl">
        Berührung, die nicht zwingt, sondern lauscht und antwortet.
      </h1>
      <p class="font-sans text-white/85 text-base md:text-lg leading-relaxed mb-10 max-w-2xl">
        Eine achtsame, tiefgehende Form der Körperarbeit — präzise Faszienarbeit mit somatischer Präsenz. Wochenendkurse in Zürich.
      </p>
      <a
        href="#module"
        class="inline-flex items-center px-8 py-3.5 bg-forest text-white rounded-btn font-medium text-base hover:bg-sage transition-colors duration-200"
      >
        Kurse ansehen
      </a>
    </div>
  </div>
</section>
