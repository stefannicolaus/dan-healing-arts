---
interface Props {
  lang?: string;
  heroMode?: boolean;
}

const { lang = 'en', heroMode = false } = Astro.props;

const isDe = lang === 'de';

const path = Astro.url.pathname.replace(/\/$/, '') || '/';

const datePaths = ['/zurich', '/portugal', '/mazunte', '/spain', '/tulum'];
const isActive = (href: string) => path === href || path === href.replace(/\/$/, '');
const isDatesActive = datePaths.some(p => path === p);

// heroMode: white links initially, switches to forest after scroll
const base = heroMode ? 'text-white' : 'text-forest';
const hover = heroMode ? 'hover:text-white/70' : 'hover:text-sage';
const activeBorder = heroMode ? 'border-white' : 'border-forest';

const linkClass = (href: string) =>
  isActive(href)
    ? `nav-link font-medium border-b-2 ${activeBorder} ${base} pb-0.5 transition-colors`
    : `nav-link font-medium ${base} ${hover} transition-colors`;

const mobileLinkClass = (href: string) =>
  isActive(href)
    ? 'text-forest font-medium border-b-2 border-forest pb-0.5'
    : 'text-forest font-medium';
---

<nav
  id="main-nav"
  class="fixed top-0 w-full z-50 transition-all duration-300 py-3 px-6 md:px-12"
  data-hero={heroMode ? 'true' : 'false'}
>
  <div class="max-w-page mx-auto flex justify-between items-center">
    <!-- Logo -->
    <a href={isDe ? '/zurich' : '/'} class="flex items-center">
      <img
        src="/images/dan-logo-v2.png"
        alt="Dan Healing Arts Logo"
        class="h-20 w-auto object-contain"
      />
    </a>

    {isDe ? (
      /* ===== DEUTSCH: Anchor-Navigation ===== */
      <>
        <div class="hidden lg:flex items-center gap-10">
          <a href="#methode" class={`nav-link font-medium transition-colors ${base} ${hover}`}>Die Methode</a>
          <a href="#module" class={`nav-link font-medium transition-colors ${base} ${hover}`}>Module</a>
          <a href="#ueber" class={`nav-link font-medium transition-colors ${base} ${hover}`}>Über Daniel</a>
          <a href="/massage" class={`nav-link font-medium transition-colors ${base} ${hover}`}>Massage</a>
          <a href="#kontakt" class="inline-flex items-center px-6 py-2.5 bg-forest text-white rounded-btn font-medium hover:bg-sage transition-colors">
            Anmelden
          </a>
        </div>
        <button id="menu-btn" class="lg:hidden text-forest p-2" aria-label="Menü öffnen">
          <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>
      </>
    ) : (
      /* ===== ENGLISH: Multi-page Navigation ===== */
      <>
        <div class="hidden lg:flex items-center gap-8">
          <a href="/about" class={`${linkClass('/about')} whitespace-nowrap`}>About this work</a>
          <a href="/level-1" class={linkClass('/level-1')}>Level 1</a>
          <a href="/level-2" class={linkClass('/level-2')}>Level 2</a>

          <!-- Dates dropdown -->
          <div class="relative group">
            <button class={`nav-link ${isDatesActive ? `font-medium border-b-2 ${activeBorder} ${base} pb-0.5` : `font-medium ${base} ${hover} transition-colors`} flex items-center gap-1 cursor-pointer`}>
              Dates
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </button>
            <!-- Dropdown submenu -->
            <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
              <div class="bg-canvas border border-stone/20 rounded-btn shadow-md min-w-[140px] py-2">
                <a href="/zurich" class="block px-4 py-2 font-sans text-stone text-sm hover:text-forest hover:bg-surface-lo transition-colors">Zürich</a>
                <a href="/portugal" class="block px-4 py-2 font-sans text-stone text-sm hover:text-forest hover:bg-surface-lo transition-colors">Portugal</a>
                <a href="/mazunte" class="block px-4 py-2 font-sans text-stone text-sm hover:text-forest hover:bg-surface-lo transition-colors">Mazunte</a>
                <a href="/spain" class="block px-4 py-2 font-sans text-stone text-sm hover:text-forest hover:bg-surface-lo transition-colors">Spain</a>
                <a href="/tulum" class="block px-4 py-2 font-sans text-stone text-sm hover:text-forest hover:bg-surface-lo transition-colors">Tulum</a>
              </div>
            </div>
          </div>

          <a href="/sessions" class={linkClass('/sessions')}>Sessions</a>
          <a href="/about-dan" class={`${linkClass('/about-dan')} whitespace-nowrap`}>About Dan</a>
          <a href="/contact" class="inline-flex items-center px-6 py-2.5 bg-forest text-white rounded-btn font-medium hover:bg-sage transition-colors">
            Contact
          </a>

          <!-- Instagram -->
          <a href="https://www.instagram.com/dan.healing.arts/" target="_blank" rel="noopener" aria-label="Instagram" class={`nav-link ${base} ${hover} transition-colors ml-2`}>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </a>
        </div>

        <button id="menu-btn" class="lg:hidden text-forest p-2" aria-label="Open menu">
          <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>
      </>
    )}
  </div>

  <!-- Mobile dropdown -->
  <div id="mobile-menu" class="hidden absolute top-full left-0 w-full bg-canvas border-t border-stone/20 px-6 py-6 flex-col gap-5 lg:hidden">
    {isDe ? (
      <>
        <a href="#methode" class="text-forest font-medium">Die Methode</a>
        <a href="#module" class="text-forest font-medium">Module</a>
        <a href="#ueber" class="text-forest font-medium">Über Daniel</a>
        <a href="/massage" class="text-forest font-medium">Massage</a>
        <a href="#kontakt" class="inline-flex justify-center px-6 py-3 bg-forest text-white rounded-btn font-medium">
          Anmelden
        </a>
      </>
    ) : (
      <>
        <a href="/about" class={mobileLinkClass('/about')}>About this work</a>
        <a href="/level-1" class={mobileLinkClass('/level-1')}>Level 1</a>
        <a href="/level-2" class={mobileLinkClass('/level-2')}>Level 2</a>
        <p class="font-sans text-xs font-bold uppercase tracking-[0.15rem] text-stone pt-1">Dates</p>
        <a href="/zurich" class={`pl-4 font-medium transition-colors ${isActive('/zurich') ? 'text-forest border-b-2 border-forest pb-0.5' : 'text-stone hover:text-forest'}`}>Zürich</a>
        <a href="/portugal" class={`pl-4 font-medium transition-colors ${isActive('/portugal') ? 'text-forest border-b-2 border-forest pb-0.5' : 'text-stone hover:text-forest'}`}>Portugal</a>
        <a href="/mazunte" class={`pl-4 font-medium transition-colors ${isActive('/mazunte') ? 'text-forest border-b-2 border-forest pb-0.5' : 'text-stone hover:text-forest'}`}>Mazunte</a>
        <a href="/spain" class={`pl-4 font-medium transition-colors ${isActive('/spain') ? 'text-forest border-b-2 border-forest pb-0.5' : 'text-stone hover:text-forest'}`}>Spain</a>
        <a href="/tulum" class={`pl-4 font-medium transition-colors ${isActive('/tulum') ? 'text-forest border-b-2 border-forest pb-0.5' : 'text-stone hover:text-forest'}`}>Tulum</a>
        <a href="/sessions" class={mobileLinkClass('/sessions')}>Sessions</a>
        <a href="/about-dan" class={mobileLinkClass('/about-dan')}>About Dan</a>
        <a href="/contact" class="inline-flex justify-center px-6 py-3 bg-forest text-white rounded-btn font-medium">
          Contact
        </a>
        <a href="https://www.instagram.com/dan.healing.arts/" target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-stone font-medium hover:text-forest transition-colors">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
          </svg>
          @dan.healing.arts
        </a>
      </>
    )}
  </div>
</nav>

<script>
  // Scroll: transparent → solid
  const nav = document.getElementById('main-nav');
  const isHeroMode = nav?.dataset.hero === 'true';
  const navLinks = nav?.querySelectorAll<HTMLElement>('.nav-link');

  function updateNav() {
    const scrolled = window.scrollY > 60;
    if (scrolled) {
      nav?.classList.add('bg-canvas/95', 'backdrop-blur-md', 'border-b', 'border-stone/20', 'shadow-sm');
      if (isHeroMode && navLinks) {
        navLinks.forEach(el => {
          el.classList.remove('text-white', 'hover:text-white/70', 'border-white');
          el.classList.add('text-forest', 'hover:text-sage');
          if (el.classList.contains('border-b-2')) el.classList.add('border-forest');
        });
      }
    } else {
      nav?.classList.remove('bg-canvas/95', 'backdrop-blur-md', 'border-b', 'border-stone/20', 'shadow-sm');
      if (isHeroMode && navLinks) {
        navLinks.forEach(el => {
          el.classList.remove('text-forest', 'hover:text-sage', 'border-forest');
          el.classList.add('text-white', 'hover:text-white/70');
          if (el.classList.contains('border-b-2')) el.classList.add('border-white');
        });
      }
    }
  }

  window.addEventListener('scroll', updateNav);

  // Mobile menu toggle
  document.getElementById('menu-btn')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
    document.getElementById('mobile-menu')?.classList.toggle('flex');
  });

  // Close mobile menu on link click
  document.querySelectorAll('#mobile-menu a').forEach(link => {
    link.addEventListener('click', () => {
      document.getElementById('mobile-menu')?.classList.add('hidden');
      document.getElementById('mobile-menu')?.classList.remove('flex');
    });
  });
</script>
