---
---

<section class="h-[100dvh] flex flex-col justify-center px-6 md:px-12 pt-[72px]">
  <div class="max-w-page mx-auto w-full flex flex-col md:flex-row items-stretch gap-8 lg:gap-16 h-full py-6 md:py-8">

    <!-- Bild: 55% — füllt die verfügbare Höhe -->
    <div class="w-full md:w-[55%] shrink-0 min-h-0">
      <div class="rounded-card overflow-hidden h-full bg-surface-mid relative">
        <img
          src="/images/daniel-bodywork.jpg"
          alt="Daniel Wendt bei der somatischen Körperarbeit — Hände auf Gewebe, ruhig und präzise"
          class="w-full h-full object-cover object-top"
          onerror="this.style.display='none'"
        />
        <div class="w-full h-full flex items-center justify-center absolute inset-0 -z-10">
          <span class="font-sans text-stone/40 text-sm">Foto folgt</span>
        </div>
      </div>
    </div>

    <!-- Text: 45% — vertikal zentriert -->
    <div class="w-full md:w-[45%] flex flex-col justify-center items-start">
      <h1 class="font-serif font-black text-forest text-4xl md:text-5xl lg:text-6xl leading-[1.05] tracking-tight mb-6">
        Berührung, die nicht zwingt, sondern lauscht und antwortet.
      </h1>
      <p class="font-sans text-stone text-base md:text-lg font-light leading-relaxed mb-8 max-w-md">
        Diese Ausbildungsreihe vermittelt eine achtsame, tiefgehende Form der Körperarbeit, in der präzise Faszienarbeit mit somatischer Präsenz verbunden wird — Wochenendkurse in Zürich.
      </p>
      <a
        href="#module"
        class="inline-flex items-center px-8 py-3.5 bg-forest text-white rounded-btn font-medium text-base hover:bg-sage transition-colors duration-200"
      >
        Kurse ansehen
      </a>
    </div>

  </div>
</section>
